  "metadata": {
    "title": "Semantic Entity Demo — One Identity, Many Names",
    "author": "Rwanga Playground",
    "created": "2026-06-05T00:00:00.000Z",
    "modified": "2026-06-05T00:00:00.000Z",
    "version": 1,
    "revision_notes": "Demonstrates the Semantic Entity Layer (S0/S1): canonical names, aliases, and repeated references resolving to one entity id.",
    "screenplayProfile": {
      "language": "en",
      "direction": "ltr",
      "screenplayConvention": "hollywood"
    },
    "production_type": "short",
    "genre": "Drama",
    "logline": "A teacher known by many names is one person to the town and to the editor.",
    "useSchemaV3": true
  },
  "settings": {
    "theme": "dark",
    "font_size": 12,
    "font_family": "Courier Prime",
    "show_scene_numbers": true,
    "page_size": "Letter",
    "pageSetup": { "paperSize": "Letter", "margins": { "top": 1, "right": 1, "bottom": 1, "left": 1.5 } },
    "vocabulary": {
      "settings": ["INT.", "EXT.", "INT./EXT.", "EXT./INT."],
      "times": ["DAY", "NIGHT", "CONTINUOUS", "DUSK", "DAWN"],
      "sceneWord": "SCENE"
    },
