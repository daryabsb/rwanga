    "units": "in"
  },
  "tag_registry": {
    "characters": [
      { "id": "ent-nali",  "name": "NALI",  "color": "#4FC1FF", "notes": "Protagonist. Known across town as 'the teacher' and 'the poet'.", "aliases": ["The Teacher", "The Poet"] },
      { "id": "ent-baban", "name": "BABAN", "color": "#FFB347", "notes": "The market man.", "aliases": ["The Butcher"] }
    ],
    "props": [
      { "id": "ent-notebook", "name": "NOTEBOOK", "color": "#DCDCAA", "notes": "Nali's poems.", "aliases": [] }
    ],
    "wardrobe": [],
    "locations": [
      { "id": "ent-classroom", "name": "CLASSROOM", "color": "#4EC9B0", "notes": "", "aliases": [] }
    ],
    "sfx": [], "vfx": [], "vehicles": [], "animals": [], "custom": []
  },
  "flag_log": [],
  "export_settings": { "branding": "rwanga", "letterhead_url": null, "include_scene_numbers": true, "include_revision_marks": false },
  "runtime": { "last_cursor": null, "active_scene_id": "scene-sem-001", "ui_state": {} },
  "body": {
    "type": "doc",
    "content": [
      {
        "type": "titleStrip",
        "attrs": { "removable": true },
        "content": [{ "type": "text", "text": "Semantic Entity Demo" }]
      },
      {
        "type": "body",
        "content": [
          {
            "type": "scene",
            "attrs": { "id": "scene-sem-001", "notes": "Establish NALI by her canonical name.", "revisionFlag": null, "metadata": { "linkedScenes": [], "references": [], "production": {} } },
            "content": [
              { "type": "sceneHeading", "attrs": { "setting": "INT.", "time": "DAY", "headingStyle": null }, "content": [{ "type": "text", "text": "CLASSROOM" }] },
              { "type": "action", "content": [{ "type": "text", "text": "Chalk dust hangs in the light. NALI closes a battered notebook." }] },
              { "type": "character", "content": [{ "type": "text", "text": "NALI", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-nali" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "Tomorrow we read it aloud. Every line." }] },
              { "type": "transition", "attrs": { "presetType": "CUT" }, "content": [{ "type": "text", "text": "CUT" }] }
            ]
          },
          {
            "type": "scene",
            "attrs": { "id": "scene-sem-002", "notes": "Same person, a different name: THE TEACHER is an alias of NALI.", "revisionFlag": null, "metadata": { "linkedScenes": [], "references": [], "production": {} } },
            "content": [
              { "type": "sceneHeading", "attrs": { "setting": "EXT.", "time": "DAY", "headingStyle": null }, "content": [{ "type": "text", "text": "MARKET ROW" }] },
              { "type": "action", "content": [{ "type": "text", "text": "BABAN wipes his hands on his apron and nods at the woman the whole row calls the teacher." }] },
              { "type": "character", "content": [{ "type": "text", "text": "BABAN", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-baban" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "Morning, teacher. Saved you the good bread." }] },
              { "type": "character", "content": [{ "type": "text", "text": "THE TEACHER", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-nali" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "You always do, butcher." }] },
              { "type": "character", "content": [{ "type": "text", "text": "THE BUTCHER", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-baban" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "Only name that ever stuck." }] },
              { "type": "transition", "attrs": { "presetType": "CUT" }, "content": [{ "type": "text", "text": "CUT" }] }
            ]
          },
          {
            "type": "scene",
            "attrs": { "id": "scene-sem-003", "notes": "A third name for the same identity: THE POET is also NALI.", "revisionFlag": null, "metadata": { "linkedScenes": [], "references": [], "production": {} } },
            "content": [
              { "type": "sceneHeading", "attrs": { "setting": "INT.", "time": "NIGHT", "headingStyle": null }, "content": [{ "type": "text", "text": "CLASSROOM" }] },
              { "type": "action", "content": [{ "type": "text", "text": "By lamplight she writes. The NOTEBOOK fills line by line." }] },
              { "type": "character", "content": [{ "type": "text", "text": "THE POET", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-nali" } }] }] },
              { "type": "parenthetical", "content": [{ "type": "text", "text": "(to no one)" }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "One person. Three names the town gave me. All of them mean me." }] },
              { "type": "transition", "attrs": { "presetType": "FADE OUT" }, "content": [{ "type": "text", "text": "FADE OUT" }] }
            ]
          }
        ]
      }
    ]
  }
}
