      "screenplayConvention": "hollywood"
    },
    "production_type": "short",
    "genre": "Drama",
    "logline": "On the night the power fails, a daughter and her father say the thing they never could in the light.",
    "useSchemaV3": true
  },
  "settings": {
    "theme": "dark",
    "font_size": 12,
    "font_family": "Courier Prime",
    "show_scene_numbers": true,
    "page_size": "Letter",
    "pageSetup": { "paperSize": "Letter", "margins": { "top": 1, "right": 1, "bottom": 1, "left": 1.5 } },
    "vocabulary": {
      "settings": ["INT.", "EXT.", "INT./EXT.", "EXT./INT."],
