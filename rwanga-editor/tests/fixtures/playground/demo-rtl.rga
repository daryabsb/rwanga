        "type": "body",
        "content": [
          {
            "type": "scene",
            "attrs": { "id": "scene-rtl-001", "notes": "دەستپێک گەرم و ئاسایی.", "revisionFlag": null, "metadata": { "linkedScenes": [], "references": [], "production": {} } },
            "content": [
              { "type": "sceneHeading", "attrs": { "setting": "INT.", "time": "NIGHT", "headingStyle": null }, "content": [{ "type": "text", "text": "چێشتخانە" }] },
              { "type": "action", "content": [{ "type": "text", "text": "هەڵمی دوو پەرداخ چا. نالی لەناو تاریکیدا دانیشتووە و چاوەڕێ دەکات." }] },
              { "type": "character", "content": [{ "type": "text", "text": "نالی", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-nali-rtl" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "ناتوانم زۆر بمێنمەوە." }] },
              { "type": "character", "content": [{ "type": "text", "text": "بابان", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-baban-rtl" } }] }] },
              { "type": "parenthetical", "content": [{ "type": "text", "text": "(بێ ئەوەی سەر هەڵبڕێت)" }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "تۆ هەرگیز نامێنیتەوە." }] },
              { "type": "transition", "attrs": { "presetType": "CUT" }, "content": [{ "type": "text", "text": "CUT" }] }
            ]
          },
          {
            "type": "scene",
            "attrs": { "id": "scene-rtl-002", "notes": "کارەبا دەکوژێتەوە. گڵۆپ دەبێتە هەموو جیهان.", "revisionFlag": null, "metadata": { "linkedScenes": [], "references": [], "production": {} } },
            "content": [
              { "type": "sceneHeading", "attrs": { "setting": "INT.", "time": "CONTINUOUS", "headingStyle": null }, "content": [{ "type": "text", "text": "چێشتخانە" }] },
              { "type": "action", "content": [{ "type": "text", "text": "کارەبا دەکوژێتەوە. بابان مشتاڵێک دادەگیرسێنێت و گڵۆپەکە بەرز دەکاتەوە." }] },
              { "type": "character", "content": [{ "type": "text", "text": "مامۆستا", "marks": [{ "type": "tag", "attrs": { "tagType": "character", "entityId": "ent-nali-rtl" } }] }] },
              { "type": "dialogue", "content": [{ "type": "text", "text": "باشە. لە تاریکیدا ناتوانیت ڕووم ببینیت کاتێک دەیڵێم." }] },
              { "type": "transition", "attrs": { "presetType": "FADE OUT" }, "content": [{ "type": "text", "text": "FADE OUT" }] }
            ]
          }
        ]
      }
