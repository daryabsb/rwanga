            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و حەوتەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . قەراخ شار"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT، NIGHT: نالی لەناو سەیارەکەی دانیشتووە. ڕووناکیی گڵۆپەکانی جادەکە بەنەرمی لێیی ئەدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە بەرزاییەکی قەراخ شارەوە وەستاوە، دور لە هەموو شتێک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلی نالی، پەیوەندی بە AI ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "\"شەبەکە نیە.\""
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکەی دادەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT: ڕووناکیی شار لە دوورەوە. نالی لەنێوان تاریکی و ڕووناکیدا، لە قەراخدا، لە هیچ شوێنێکدا."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-043",
              "notes": "",
              "revisionFlag": null,
