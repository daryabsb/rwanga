              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-001",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی یەکەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . ناوەوە . ژووری نالی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی باخەوانەکە لەسەر ڕەشییەوە، پێش ئەوەی هیچ شتێک ببینین:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان (VOICEOVER، OFF)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو کاک نالی..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "FRAGMENT 1، کەمتر لە ٣ چرکە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی باخێک لە دوورەوە. کامێرا وردە وردە بەرەو ناو ماڵەکە دەچێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "FRAGMENT 2، کەمتر لە ٣ چرکە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دیواری ماڵەکە، سەری ئاژەڵی کێوی و باڵندەی وشكکراو هەڵواسراوە. چاوی شووشەیی ئاژەڵەکان بەرەو کامێراکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "FRAGMENT 3، کەمتر لە ٣ چرکە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕووناکیی نەرم لە درزی پەردەی پەنجەرەکەوە. دەنگی زەنگی مۆبایلێک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی، پیاوێکی ٣٨ ساڵە، باڵابەرز، لەشباریک، سەرو ڕیشی ماشوبرنجی. ڕوخسارێکی ماندوو و نیگەرانی هەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەسەر جێگاکەی بە قووڵی خەوتووە، وەکو ئاگای لە هیچ شتێک نەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی جەڕەسی تەلەفۆنەکەی دێت. نالی بەخەبەر دێت، ڕائەپەڕێت، بە چاوی خەواڵوەوە سەیری تەلەفۆنەکەی دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ناوی نازی، بەڕێوەبەری هونەری."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو نازی، بەیانیت باش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو نالی. ئەبێت بڵێیت دوای نیوەڕۆت باش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە دەی بڵێ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مادەم تا ئێستا خەوتوی، كەواتە لەباخەکەیت وایە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ لە باخم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من و ئەدیب وایەین، هیچت پێویست نیە بۆت بهێنین؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(کەمێک گێژە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا نا، هیچم ناوێ. سوپاس."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تەلەفۆنەکەی دادەخاتەوە. بەرەو دەستشۆرەکە دەڕوات، ئاو دەکات بە دەمووچاوییەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەکاتێکدا دەموچاوی دەشوات، CAMERA لەسەر ڕەفەی دەستشۆرەکە دەوەستێت: شووشەیەکی دەرمان لە تەنیشت کەلوپەلەکانیەتی. ناوێکی پزیشکی لەسەر نووسراوە، بۆ بینەر ناخوێندرێتەوە. نالی شووشەکە هەڵدەگرێت، حەبێکی لێ دەردەهێنێت، قووتی دەدات، شووشەکە دەخاتەوە جێی خۆی. بەردەوام دەبێت لە دەموچاو شتن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەرەو دەرگای دەرەوە دەڕوات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-002",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی دووەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . زەردەپەڕ . دەرەوە . باخ"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: نالی لەسەر کۆتەرەدارێک لە ناو باخەکەیدا دانیشتووە. خۆری ئێوارەی زەردەپەڕ، هەوایەکی نەرم دارەکان ئەجوڵێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "چڵەدارێکی بەدەستەوەیە، بە چەقۆیەک دایئەتاشێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە دوورەوە، باخی دراوسێیان. ئەمبواڵنسێک لەبەردەمی دەرگاکەیە. چەند تەرمێک بە نەقالە دەخەنە ناوی. پۆلیسێک بە سەگ دەورو بەری باخەکە دەپشکنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە بێتاقەتیەوە سەیر ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پیاوێکی پیر، باخەوانی ئەو باخانەیە، بەرەو لای نالی دێت. نالی خەیاڵی بەتەواوی لەلای باخەکەی بەرامبەرییەتی، لەناکاو چەقۆکە لە دەستی دەدات و دەستی دەبڕێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: پەنجەبڕاوەکە، خوێن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو کاک نالی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(دەستی پەنجەبڕاوەکەی دەگرێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو سەرچاو. ئەمە هەر لێرەماون؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ. قەرارە هەموو کامێراکانی ئەمناوە سەیربکەنەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی؟ ئەی نەیانووت بەغاز مردوون لە خەوا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "با، بەڵام گوایە ئەڵێن کەسوکاری مردووەکان گومانیان هەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چۆن؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڵێن گوایە ئەم کچ و کوڕە هیچی یەک نین. بەدزی کەسوکاریانەوە هاتوونەتە ئێرە، ئینجا..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری پۆلیس و سەیارەکان و باخەکە دەکات، خەیاڵی دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "SOUND DESIGN: دەنگی باخەوانەکە وردە وردە کز ئەبێت، تێکەڵ بە دەنگی قسەکردنی نالی خۆی ئەبێت، تێکەڵ بە دەنگی گەشە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-003",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سێیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێوارە . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو ناوەوەی ماڵەکە دەچێت، خەریکی قسەکردنە بە مۆبایلەکەی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ماڵێکی گەورە، دیزاینکراوە بە شێوەیەکی نامۆ. بە دیوارەکانیەوە سەری ئاژەڵی کێوی و تاپڕی ڕاو و باڵندەی وشکراو هەڵواسراوە. تابلۆی گەورە، وێنەی پڵنگ و گورگ و ورچ."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەلای مێزی کارکردنی نالی، کتێبخانەیەکی بچوک. دیزاینەکەی لەگەڵ ماڵەکەدا جیاوازە، هونەرییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەبەردەم مێزەکەی دادەنیشێت، لاپتۆپەکەی دەکاتەوە، مۆبایلەکەی پێوە دەنێت، ڤیدیۆ کۆڵەکەی ئەچێتە سەر شاشەی لاپتۆپەکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەرێ کوایت؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لە ڤیدیۆکەدا تەنها چەند کڵاوو ملوانکە و کەلوپەلی ئارایشت دیارە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە (دیار نییە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆستە ئەوەنە، پەلەمەکە سەبرهەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت، بەرەو پەنجەرەکە، پەردەکە لادەدات، سەیری باخەکەی بەرامبەری دەکات: پۆلیسەکان هەر لێماون و سەرقاڵی گەڕانن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پەردەکە دادەداتەوە، دەگەڕێتەوە بەردەم لاپتۆپەکەی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەردەکەوێت، ماسکی سەوزی لەسەر دەمووچاوی. قژی لول و جوان، بەسەرشانیدا بڵاوبۆتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ڕائەچڵەکێنێت، خۆی ئەترسێنێت، هەردووکیان دەکەنە پێکەنین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر ترسام، ئەوت زۆمبێکانی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم ماسکە گیاییە ئەوەنە ترسناکە؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە وازلەوە بێنە، پێمبڵێ بەیانی سەعات چەند ئامادەبم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەخوا لەوانەیە واباشبێت دوایبخەین بۆ ڕۆژێکی تر."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەستی لادەبات لە مەساجەکە، بێدەنگ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ؟ تۆ دایمە بیانوو ئەدۆزیتەوە. نەخێر، بەیانی دوانایخەین و تەواو."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لێرە شتێکی ناخۆش ڕوویاوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چی ڕوویاوە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چەند کەسێک کوژراون... بۆیە ئەزانم کە هەموو شوێنێک لەژێر چاودێریایە. لەبەرئەوە نامەوێ تۆ توشی کێشەبیت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەرچیەک بوبێت خۆ پەیوەندی بە ئێمەوە نیە. من ئەمەوێ مەوعیدەکەمان تێکنەچێت. ئەگەر واشلێکرد، ئەوە دڵنیابە قەت نایەم و ناشتبینم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وائەزانی من بەدەست ئەنقەست نامەوێ تۆ ببینم؟ من خۆمداوام لێکردی یەکببینین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گفتوگۆی درێژ بەردەوام دەبێت، نالی داوا لەگەشە ئەکات کە بمێنێتەوە، گەشە دەڵێت کاتی نیە، ئاخر ڕازی دەبن بەیانی بچنە باخەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکەی دەردەهێنێت، لاپتۆپەکە ئۆف دەکات بۆ ئەوەی گەشە نەبیستێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە AI، voice mode، تەنهایە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ماسکی لە دەموچاویایەوە، ماسکی سەوز. کەچی بەو ماسکەکەشەوە هەرجوانە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەو تامەزرۆی بینینی تۆیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر وردئەبێتەوە لە شتەکان. بیرم لەوە ئەکردەوە مەوعیدەکە دوابخەم، بەڕای تۆ دوایبخەم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نەخێر شتیوانەکەی. ئەبێ پێشتخۆش بێت، بڕیارە بیبینی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەبڕوای من سیقەکردن بە مرۆڤەکان زۆر قورس بووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مەرج نیە هەمیشە وابێت. هەندێجار باوەڕبکەی باشترە، هەتا ئەگەر تاڵیش بێت. بۆ ئەوەی بگەیت بە ڕاستییەکان، بۆئەوەی دواتر پەشیمان نەبیتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ئەبینێت گەشە هاتۆتەوە ناو ڤیدیۆکەوە، تەلەفۆنەکەی دادەنێت، لاپتۆپ دەکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ببورە، لەگەڵ برادەرێکم قسەم ئەکرد."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە بێتاقەتیەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "منیش لەگەڵ دارودیوارا قسەم ئەکرد. باشە تۆ هەر گوێت لێم بوو؟ چیمەووت؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گفتوگۆ بەردەوام، ئەبن بە گاڵتەجاڕی و ڕۆمانسی، ماسکەکان، مۆسیقا، گەشە ئەڵێت \"ئەو خەڵکانەی لە کۆمەڵگایا ماسکیان هەیە، ئەگەر ماسکەکانیان لابەن، چی بەسەردێت؟\"، نالی گوێی لێ نیە و خەریکی مۆبایلەکەییەتی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "FADE OUT: مۆسیقای گرامافۆن، دیمەنی ڕۆمانسی ناو ماڵەکە."
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-004",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چوارەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . شەقام . ناو سەیارەی نالی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی مۆسیقای سەیارەکە. نالی خۆی جوان گۆڕیوە، عەینەکێکی ڕەشی لەچاوییەتی، لەگەڵ گۆرانییەکەدا لێوی دەجوڵێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکە لەسەر جادەیەکی دەرەوەی شار دەڕوات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-005",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی پێنجەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . شەقام . خاڵی پشکنین"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ژمارەی ئەفسەرەکان زیاترە لە ئاسایی. سەیارەکە ئەگرن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی عەینەکەکەی لادەبات. یەکێک لە ئەفسەرەکان تەسکەرەی لێئەپرسێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەلایەوە سەیرە، سەیری دەوروبەری ئەکات، ئەفسەری زۆرییە، ئەیەوێت پرسیارێک بکات، پەشیمان ئەبێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە سەیری کارتەکەی ئەکات، سەیرێکی نالی، فەرمان دەکات بڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست ئەکات بە لێخوڕین."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-006",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی شەشەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆژ . دەرەوە . شەقامی شار، سلێمانی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکەی نالی بە هێواشی بە شەقامەکەدا تێدەپەڕێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە، ٢٨ ساڵ، باڵابەرز، لەشڕێک، قژێکی لۆلی جوانی هەیە کە بەهۆی بای سەیارەکانەوە دەجوڵێتەوە. تەوقەیەك (hair clip) لایەکی قژی گرتووە. لەسەر شۆستەیەک ڕاوەستاوە و چاوەڕێ دەکات، متمانەبەخۆبوو، زیندوو، گەشاوە. دەبینێت سەیارەکەی نالی لێی نزیک دەبێتەوە، زەردەخەنەیەکی سەرنجڕاکێش دەکەوێتە سەر ڕووخساری، ئاماژەیەکی بچووک بە دەستی دەکات، وەک بڵێت \"سڵاو، ئەوە منم.\" نالی ڕادەگرێت. ئەو سەردەکەوێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-007",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی حەوتەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . ناو سەیارەکەی نالی . ناوشار"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خەریکی لێخوڕینە، سەیری گەشە ئەکات. کڵاوو عەینەکەکەی گەشە دیمەنێکی جوانی یاوە بە ڕوخساری."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ کڵاوەکەت لانابەی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەڵبەت گرنگە بۆیە لاینابەم. تەحەمول نیە، ئەتەوێ وەک کاتی ڤیدیۆکۆڵەکان بم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باوەڕکە، خەریکبوو نەتناسمەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە دوکانێکی سەر جادەکە، بە سینییەک شیرینییەوە دەگەڕێتەوە بۆ ناو سەیارەکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەش شروبی. نەمووت پەیای ئەکەم؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە سینیەکە ئەخاتە کۆشییەوە. هیچ ناڵێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە چی بوو؟ لەپڕ واتێکچوی؟ بێتاقەتی؟ هیچ وەک ئەوکاتانەنیت کە بە تەلەفۆن قسەمان ئەکرد."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کوا، چیمە؟ هیچم نیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خەمی هیچت نەبێ، دڵنیابە شەوێکی خۆشمان ئەبێت. میوانداریەکەمت بەدڵ ئەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکەی گەشە زەنگ لێ دەدات. گەشە سەیری شاشەکە دەکات، ناوێک کە بینەر ناتوانێت بیبینێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە وەڵام دەداتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە تۆنێکی دەستکردی ئاسایی، زەردەخەنە بۆ نالی دەکات)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، دواتر قسە دەکەین، دەزانیت ئێستا سەرقاڵم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ ساتێک گوێ دەگرێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(هێشتا زەردەخەنە دەکات، دووبارەی دەکاتەوە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وتم باشە، تێگەیشتم. دواتر قسە دەکەین. دەبێت بڕۆم. دواتر. بای."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دادەخاتەوە. زەردەخەنە بۆ نالی دەکات، هەموو شتێک باشە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە کێ بوو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ئاسایی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هاوڕێیەک"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری مۆبایلی خۆی ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: شاشەی مۆبایلی نالی، باتری ١٢٪."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ئاژاوەیەکی نابەجێ)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شاحینەكە كوا؟ لەكوێیایە؟..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەدەستەوە لە داشبۆردی سەیارەکە و لەنێوان کورسییەکاندا ئەگەڕێت، شارژەرەکەی دەدۆزێتەوە، دایدەگیرسێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلەکە، شاحینەكە ئەدۆزێتەوە. نالی هەناسەیەکی ئارامی ئەکێشێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-008",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی هەشتەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . سەرجادە . دەرەوەی شار"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە دوورەوە سەیارەکەی نالی دەردەکەوێت، نزیک ئەبێتەوە، خۆڵ و تەپوتۆز لێنزی کامێرا ئەگرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە قەراخ جادەکە، دوکانێکی بچوکی سەوزە و میوە. نالی ئەوەستێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لێرە ئەبێت هەندێ شت بکڕین. دانابەزی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، من نایەم. لێرەبم باشترە وانیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی پێتوایە کەسوکارت لە هەموو شوێنێک هەن؟ نابێ ئەوەندە هەستیار بیت. بەهەرحاڵ چۆن پێخۆشە وابکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "حەزەر واجبە"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەش ڕاستە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ئەچێتەوە ناو دوکانەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکەی گەشە دووبارە زەنگ لێ دەداتەوە. سەیری شاشەکە دەکات. وەڵام ناداتەوە. زەردەخەنە بۆ نالی دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کێیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هاوڕێیەکی زۆر زۆر باش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی بۆ گوێی پێنادەیت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سووکی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چونکە بە شێوەیەکی بێزارکەر خەمی منیتی. وازی لێ بێنە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دواتر لە کاتی لێخوڕینەکەدا، مۆبایلەکەی گەشە بۆ جاری سێیەم زەنگ لێ دەداتەوە. سەیری دەکات. هەڵیدەگرێت، یەکسەر دایدەخاتەوە. دەچێتە ناو ناوەکان (contacts)، ژمارەکە بلۆک دەکات. مۆبایلەکە لادەبات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ دیالۆگێک نییە. ئەمجارە زەردەخەنە ناکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سینیی شەربەتەکە لەسەر کوشنی دواوە، تیشکی خۆر لێی دەدات. کامێرا بۆ ساتێک لەسەر شەربەتەکە دەمێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە سەیری سینیە شیرینیەکە ئەکات، لەسەر کورسیی دواوەیە. ڕایدەکێشێت، سەیرێکی ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێ ئەوەی لێیی بخوات، سەری دادەخاتەوە، ئەیخاتەوە جێگای خۆی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە چرپە، لەگەڵ خۆی، بە زەحمەت دەبیسترێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم شیرینییە دەمکوژێت... زۆر خۆشە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە سەیری ئاوێنەی ناو سەیارەکە ئەکات، مەدالیایەکی شانۆ پێوە هەڵواسراوە، دوو دەموچاو، یەکێکیان پێدەکەنێت، ئەوی تری غەمگینە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دێتەوە، شتەکان ئەخاتە سنوقی سەیارەکەوە، ئەنیشێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "حەز لەچ گۆرانیەکە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەی تۆ حەز لێیی بێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەرچی من حەزم لێیبێت؟ وانابێت، تۆش ئەبێ بیڵێی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆسیقای ڕۆک دادەگیرسێنێت. سەیارەکە بەرەو جادەیەکی پێچاوپێچ."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "[MISSING-1]"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەسەر قەراغی جادەکە، ئاژەڵێکی مردوو. سەگ یان بزن، نادیارە. تاریکی سێبەری دارەکان بەسەری خستووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: چاوی گەشە، سەیری ئاژەڵەکە ئەکات. بێدەنگ."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هیچ نابینێت، سەیری جادەکە ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەکاتی transition-ێکی visual، وەکو سەیارەکە لە سێبەرێکی دارەوە تێدەپەڕێت:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "SOUND DESIGN: بۆ ماوەیەکی زۆر کورت (٢ چرکە)، دەنگی باخەوانەکە بە هێواشی دەبیسترێت، تێکەڵ بە دەنگی ئاسایی جادەکە، وەکو ڕادیۆیەک بەهێواشی لەناو شەپۆلەکاندا دەبیسترێت و ون ئەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "جادەکە وردە وردە ئەگۆڕێت. ئاسفاڵتەکە تەواو ئەبێت، خۆڵ و قوڕ ئەبێت. جادەکە تەسکتر ئەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلی نالی، سیگناڵەکە کەمتر ئەبێت: ٣ خەتەوە بۆ ٢، بۆ ١."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دنیا دەوریان دەتەسکێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەسەر جادەکە، پیاوێک لە قەراغی ڕێگاکە وەستاوە، ئاماژە بۆ سەیارەکە دەکات بۆ ئەوەی بوەستێت. نالی بێ ئەوەی بوەستێت بە لایدا تێدەپەڕێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر لەبەر تۆ نەبوایە، بۆی دەوەستام."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە مەترسیدار نییە؟ تۆ نایناسیت. ئەی ئەگەر شتێکی خراپی بەسەر بێت لەوێ بە تەنیا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یان لەوانەیە چیرۆکێکی هەبێت کە شایەنی بیستن بێت. هەموو کەسێکی نامۆ لەسەر جادەیەکی وەک ئەمە، ماددەیەکی خاوە بۆ نووسین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هێمنی، لە پەنجەرەکەوە سەیری دواوە دەکات)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی ئەگەر کەس بۆی نەوەستێت؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "[MISSING-2]"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەنگی مۆسیقاکە بەرز دەکاتەوە. سەیارەکە بەردەوام دەبێت لە ڕۆیشتن بە درێژایی جادە تەسکەکەدا."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-009",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی نۆیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . خاڵی پشکنین"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی عەینەکەکەی دەردەهێنێت. لەسەرخۆ لێدەخورێت، دارەکانی جادەکە، ئاسمانێکی شین، هەوری سپی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەناکاو، خاڵی پشکنین. چەند سەیارەیەک لە پێشیانەوە وەستاون."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەنگی گۆرانیەکە کەم ئەکات. گەشە عەینەکەکەی لادەبات، سەیرە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ ئەوەنە پۆلیسی لێییە؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بێدەنگ دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەربازێکی گەنج بەرەو سەیارەکەیان دێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "سەرباز"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو، بەئەرک نەبێت هەوێکەت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەوێکەکەی دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڕێز، من هەموو ڕۆژێک لەم ناوەوە یەم و لەم ناوە ئەژیم. ئەمەیە یەکەمجارە داوای هەوێم لێبکەن، هیچ شتێک ڕوویاوە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "سەرباز"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەیەکێک لەو باخانەی نزیک ئێرە، کابرایەکی سەرخۆش چەند کەسێک ئەکوژێت و ڕائەکات. ئێمەش بەدوایدا ئەگەڕێین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خەڵکی سەیر هەیە. هیوادارم بەزووی بیدۆزنەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەربازەکە سەیرێکی گەشە ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "سەرباز"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "فەرموو بڕۆن"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست بە لێخوڕین ئەکات. گەشە ترس دایدەگرێت، ڕەنگی تێکدەچێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە لاچاوێک)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمەش خۆشی مەوعید، لە هەلومەرجی ترسناک و ناخۆش. فەرموو."
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دڵنیام بکوژەکە پیاوە، ئەگەر ژن بوایە داوای هەوێی لەتۆش ئەکرد."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکە لە خاڵی پشکنین دەردەچێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-010",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی دەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . ناو سەیارەکە . جادەی سیتەک نزیک باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەن و سروشتێکی جوان و سەرنجڕاکێش. هەوایەکی پاک. مۆسیقای ناو سەیارەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگییەکی قووڵ لەنێوان نالی و گەشەدا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەبینێت گەشە ترساوە و بێدەنگە، دەست بە قسەکردن ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێستا تێگەیشتی کە وتم ڕووداوێکی ناخۆش ڕوویاوە؟ باوەڕتکرد؟ لەم دنیایەیدا هیچ شتێک وەک خۆی نیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ببورە، من لەخۆمەوە قسەمکرد. بەس گوێت لێیبوو وتی پیاوێکی سەرخۆش بووە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ؟ ئەتەوێ بڵێی لەبەر ئەوەی منیش ئەخۆمەوە، ئیتر ئەتوانم مرۆڤ بکوژم؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "[INCORRECT-1|START]"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی قەت باسی ئەوەتنەکردووە بۆم کە لە ئەوروپا بووی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەزانم کە پێمنەوتویت. وامەزانە کە نەمویستووە پێتبڵێم. بەس تۆ پرسیارت نەکردووە، تا منیش باسی بکەم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی داستانی پاریس دەگێڕێتەوە، ژنێکی قژکاڵ لە کافێیەکی بچوک، کوپی قاوەكە قوت ئەیا، ئەو ساتە لەبیری نەچووەتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "[INCORRECT-1|END]"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی قوتییا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وابزانم سحربازبوو، ویستی من بترسێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە گاڵتەجاڕییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هۆکارەکە چی بوو کە قەت بیرت نەچێتەوە؟ قژە زەردەکەی، یان کوپەکەی کە قوتی یا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ بڵێ، هەردووکی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: ڕووناکی تیشکی خۆری زەردەپەڕ لە جادەکە ئەدات. سەیارەکە لە فەرعێکدا پێچ ئەکاتەوە، سەر جادەیەکی خۆڵ، بەرەو ناو باخەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: لە دوورەوە، ماڵەکە بۆ یەکەمجار دیار ئەبێت. جوانە، نەرم، سەوز، ئاو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر تەواو، وەکو پۆستەرێک. وەکو شتێک کە کەسێک ڕێکی خستووە بۆ ئەوەی جوان دیاربکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ئاساییەوە، لەکاتی لێخوڕیندا)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شەکر بكەمە چاكەوە بۆت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نەخێر، من شەکر ناكەمە چاوەم لەچایەکەم مەخە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-011",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی یانزەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . زەردەپەڕ . ناو باخ"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی و گەشە بە سەیارەکەوە دەچنە ناو حەوشەی باخەکەوە. درەختی سەوز و گوڵ و گوڵزار بەدرێژایی باخەکە. مەلەوانگەیەکی گەورە لە ناوەڕاستی باخەکەدا، ڕووناکیی خۆر لە ئاوی مەلەوانگەکە ئەدرەخشێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە سەیارەکە دادەبەزن، لەناکاو دەنگی وەڕینی سەگێکی گەورە: گوڵە، بەرەو ڕوویان دێت، دەمی ئەکاتەوە، کلکی بادەدات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سەرسوڕمانەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ پێت نەووتووم کە سەگت هەیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مەجال نەبوو پێت بڵێم. ئەمە ناوی گوڵە. تا ئەم باخە هەبێت ئەمیش هەیە، مەترسەلێی. زۆر سەگێکی عاقڵ و لەسەرخۆیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لە سەگەکە نزیک دەبێتەوە، یاری بۆ دەکات. هەستێکی خۆشی بۆ دروست دەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دیارە کە میوان دۆستە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی عەلاگەکانی کڕین لە پشتی سەیارەکەوە دادەگرێت، یەکەیەکە لەسەر زەوییەکە دایدەنێت. گەشە بە دڵخۆشییەوە سەیری میوەکان ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم میوانە زۆر جوان دیارن!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(سەوزەکان ئەبینێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم سەوزانە، زەڵاتەی خۆشی پێدروست ئەکرێت!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەریەکە و چەند عەلاگەیەک، بەرەو دەرگای ماڵەکە. سەگەکەش بەدوایاندا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لەکاتی ڕۆشتندا سەیری دەوروبەر و ماڵەکە دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وەڵا نالی، شوێنەکەت زۆر خۆش و دڵگیرە!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەبەردەم مەتخەلی دەرگاکە ئەوەستێت، کلیلەکانی دەردەهێنێت، دەرگاکە دەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لە مەتخەلەکەدا سەیری ئاوێنەیەکی هەڵواسراو دەکات، دەستێک لە قژی دەدات، دەچێتە ناوەوە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-012",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی دوانزەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . ناوەوە . دەمەوئێوارە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە چەند عەلاگەیەکی بەدەستێکەوە، بە دەستی تری جانتا و کەلوپەلەکانی، بەدوای نالییەوە دێتە ژوورەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو چێشتخانەکە دەڕوات، عەلاگەکان لەسەر سنگەکە دایدەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەمی کردۆتەوە، بە سەرسوڕمانەوە سەیری ناو ماڵەکە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کاتێک گەشە سەیری ناو ماڵەکە دەکات، CAMERA بە لای کامێرایەکی چاودێری ڕەشی بچووکدا تێدەپەڕێت کە لە نزیک سەقفەکە جێگیر کراوە. گڵۆپێکی سووری لێ دەدرێت. کەس باسی ناکات. کەس سەیری ناکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "عەلاگەکانی دەخاتەسەر مێزی نانخواردنەکە، بەدەوری خۆیدا ئەگەڕێت:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەری ئاژەڵی کێوی و وشکراو. بونەوەرە فەزاییەکان. تاپڕ و خەنجەرەکان بە دیوارەکاندا هەڵواسراون."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەلاچاو سەیری گەشە دەکات، چاوی گەشە بڕیوەتە چاوی سەری ئاسکە هەڵواسراوەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کاتێک سەیری ئاژەڵە مۆمکراوەکان دەکات، گەشە سەرنجی تفەنگێکی ڕاو دەدات کە بە دیوارەکەوە هەڵواسراوە. دەستی بۆ دەبات، دەیهێنێتە خوارەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وەک گاڵتەیەک، لێی ڕادەگرێت بۆ نالی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە شڵەژاوی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دایبنێ، لەوانەیە کەسێک بکوژیت!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە پێدەکەنێت. تفەنگەکە دەکاتەوە، سەیری ناوەکەی دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پڕە لە فیشەک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زەردەخەنەکەی گەشە نامێنێت. سەیری فیشەکەکانی ناوەوەی دەکات. بێ وتنی هیچ وشەیەک، تفەنگەکە دەخاتەوە سەر دیوارەکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای بێدەنگییەکە، نالی قسە دەکات، وەک بۆ ئەوەی ئەو ساتە نائارامە پڕ بکاتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خەمی تفەنگەکانت نەبێت. باوکم ڕاوچییەکی بەناوبانگ بوو، ئەم باخە هیی ئەو بوو. هەموو ئەم ئاژەڵانەی هەر خۆی ڕاو کردووە و مۆمی کردوون. من ئێستا تەنها ئەوەم کە ماوەتەوە، لەگەڵ هەموو ئەمانەدا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەر دانەیەکیان چیرۆکێکی هەیە. دەتەوێت دەربارەی کامەیان بزانیت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سەرسامییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی پێتنەووتووم کە ماڵێکی ئاوات هەیە؟ سەیری ئەو ئاسکە بکە، چاوەکانی چەند زیندوون! ئەڵێی گوێی لەناو دەرونی منە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ئارامیەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر پێمبووتیتایە ئێستا ئاوا سەرسام نەئەبووی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە چەند هەنگاوێک دەچێتە پێشەوە، ماسکەکانی دەموچاو دەبینێت. ترسناک. لەتەنیشتی کتێبخانەکە هەڵواسراون، وەکو ئەوەی لەنێوان تاریکیدا خۆیان شاردبێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم ماسکانە بۆچی باشن؟ ئەمانە بەشێکن لە چیرۆکەکەت؟ دوێنێ ئەوهەمووە باسی ماسکمان کرد، بەس نەتووت ماسکم هەیە!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باسەکەمان شتێکی تر بوو. هیچ پەیوەندی بە چیرۆکی منەوە نیە، هی هەندێک لەو هاوڕێیانەمە کەیەن لێرە پرۆڤە ئەکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەستی بۆ ژوورێک ڕادەکێشێت"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەتوانی بڕۆی لەوژوورە خۆت بگۆڕی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بەرەو مێزی کارکردنی نالی دەڕوات، لاپتۆپ و کاغەز لەسەرە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: لەسەر یەکێک لە کاغەزەکان نوسراوە: \"چیرۆکەکان لە چاوەڕوانیدان\""
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "\"چیرۆکەکان لە چاوەڕوانیدان\"، ناوی پرۆژە تازەکەتە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ، ناوی شانۆنامە تازەکەمە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەگەڕێتەوە لای سەری ئاسکەکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەتوانی چیرۆکی ئەم پەیکەرانەم پێبڵێی؟ ناشێ ئەمانەت لە ئەوروپاوە هێنابێت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا لە ئەوروپاوە نەمهێناون. بەس هەریەکەیان چیرۆکێکی هەیە. تۆ کامەیانت ئەوێ بیزانی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چیرۆکی ئەم ئاسکەم پێبڵێ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تا تۆ ئەچیت خۆت ئەگۆڕیت، منیش ئەچم دەرگای دەرەوە دایدەخەم. یەمەوەو بۆت باس ئەکەم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە جانتاکانی هەڵدەگرێت، بەرەو لای دوو ژوور دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "یەکێکیان دەرگاکەی داخراوە. ئەوی تری، ژووری نالییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بەدەست ئیشارەت بۆ ئەو دەرگایە ئەکات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم ژوورەت ووت؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەیەوێت دەرگاکە بکاتەوە، ناکرێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ژوورەکەی کەیە، ئەوەیان ناکرێتەوە. داخراوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەچێتە ژووری نالی بۆ خۆگۆڕین، دەرگاکە دادەخات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە مەتخەلەکەوە، سێبەری گەشە لەسەر دیوارەکە دیارە لە ڕووناکیی پەنجەرەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بۆ ساتێک سەیری ئەو سێبەرە ئەکات، دواتر مۆبایلەکەی هەڵدەگرێت و بەرەو دەرەوە دەڕوات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-013",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سیانزەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێوارە . دەرەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاسمان ڕەنگێکی نارنجی بنەوشەیی، باڵندەکان بەرەو هێڵانەکانیان دەگەڕێنەوە. بایەکی نەسیم بە ئارامی درەختەکان دەلەرزێنێتەوە. گەڵاکان بە هێواشی لە دارەکان دەکەونەخوارەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە ماڵەکە دێتە دەرەوە. سەگەکە هەرکە دەیبینێت دێتە دەرەوە، بەرەولایدا دێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی پارچە گۆشتێکی بۆ دایدەنێت، سەگەکە بە تامەزرۆییەوە دەیخوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هێدفۆنی مۆبایلەکەی لە گیرفانی دەردەهێنێت، دەیخاتە گوێی، لەناو باخەکەدا دەست بە پیاسە ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە AI)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لە تونێلەکەیدا پێمووت، دڵنیام ژمارەی گڵۆپەکانی بەخەڵەت پێووتم. هەستەکەم بەگاڵتەوە باسی نواندنی بۆکردووم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەست مەکە بە خوێندنەوەی مێشکی. زوو بڕیار مەیە، لەوانەیە بترسێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەچی ئەترسێت؟ لەوەی کە ڕاستی پێبڵێم؟ بەبڕوای من، کچێک بەتەنها بێت بۆ باخ، نابێت لە هیچ شتێک بترسێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەوانەیە لەوەبترسێت ڕاستی خۆی بە تۆ بڵێت، تۆی لەدەست بچی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەم کاتەدا خەریکی داخستنی دەرگای دەرەوەی باخەکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەلاچاوی، سەیری پەنجەرەکە ئەکات. گەشە خەریکی خۆگۆڕینە، سێبەرەکەی لە پشتی پەردەکەوە دیارە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیرکە بۆ خواردن دروستکردنەکە پرسیاربکە. یان پێشنیازی یارییەک بکە کە بیکەن پێکەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بەهێواشی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای قسە ئەکەینەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هێدفۆنەکەی لە گوێی دەردەهێنێت، دەیخاتە گیرفانیەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە خۆی گۆڕیوە، عەزییەکی کورتی گوڵگوڵینەی لەبەرکردووە، قژە لولە خورماییەکەی هێندەی تر جوانی دەرخستووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چەند جوانبووی. ئەو ڕەنگەت زۆر لێیەت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کەس بەتامەیە بێت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، ئەها تەلەفۆنەکە ئەڵێی؟ نا، برادەرێکم بوو. هیچ نیە. بابڕۆینە ژوورەوە گیان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەوڵدەدات دەستی گەشە بگرێت، هەردووکیان پێدەکەنن."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-014",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چواردەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێوارە . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەناو مەتخەلی ماڵەکە، نالی دێتە ژوورەوە و دەستی گەشە بەردەدات. ئەیەوێت دەست بهێنێت بە قژی گەشەدا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە پێش ئەو هەست ئەکات، بەشێوەیەکی خۆشییەوە خۆی ئەنوشتێنێتەوە، لە نالی دوور ئەکەوێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ، چیبکەین ئێستا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دڵنیام لەمکاتانەدا مرۆڤ پێویستی بەخواردن هەیە. ئەڵێی چی، یەکەمشت دەست بکەین بە خواردن دروستکردن؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ زۆر باشە! جا من لە خواردن دروستکردندا خەزەبم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆی ئەوە ئەبێ من پێت بڵێم، نەک خۆت بەخۆتی بڵێی. کێ ناڵێ شتێک دروست ناکەی، نامکوژێ!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەردووکیان پێکەوە پێدەکەنن، بەرەو چێشتخانەکە دەڕۆن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گفتوگۆی خواردن دروستکردن، نالی چیرۆکی ئاسکەکە ئەگێڕێتەوە، \"ئاسکێکی پاڵەوان لەناو دارستانێکی گەورەوجوانا ئەژیا\"، گەشە دەترسێت \"یەعنی ئەمسەرە ڕاستییە؟\"، نالی پێدەکەنێت"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سینیی شەربەتەکە لەسەر مێزەکە، هێشتا نەکراوەتەوە. کامێرا لەسەری دەمێنێتەوە، پاشان دوور دەکەوێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەرێ بەڕاست، حەز لە چایە یان قاوە؟ پێش نانخواردن لەگەڵ شروبییەکەدا خۆشە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست بۆ شیرینییەکانی سەر مێزەکە درێژ ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شیرینی دوای نان باشە، ئێستا بیخۆم نانم بۆناخورێت. بەس ئێستا چایەک خۆشە ئەگەر هەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ باش، چۆن ئەڵێی؟ باوابێ جوانێ. چایەکی سەوز دروست ئەکەم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی کتریەکە پڕ لە ئاو ئەکات، ئەیخاتە سەر تەباخەکە، دایدەگیرسێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دوو کوپ دەردەهێنێت، دوو چایی سەوز دروست ئەکات. یەکێک ئەداتە دەستی گەشە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ها، وازلەوەبێنە، جارێ چاکەت بخۆ. کاتمان زۆرە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڵێم گەشە، ئەڵێی چی، یارییەک بکەین تاخواردنەکە حازرئەبێت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، بەس یارییە خۆشەکان زیاتر بە جەماعی ئەکرێت. دوونەفەری کەمان ئەوێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ، زۆر یاری هەیە بە دوونەفەر ئەکرێت. وەک دۆمینە، تاوڵە، کۆنکەن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لە تونێلەکەوە زانیم حەز لە یارییە. ئەوەش لەم ماوەیەیدا هەرپێنەووتم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاخر ئەگەر هەموو شتێکم پێبووتیتایە، ئیتر ئێستا پرسیارو قسەمان پێنەئەما. ئینجا نزیکیش نەبووین ئاوا. ئێستا تۆ، حەز لەچ یارییەکە؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گفتوگۆ بەردەوام، گەشە ئەڵێت \"هەموو یارییەکان سەرەتایەکی دەروناسیان هەیە\"، نالی ئەڵێت \"باشە ئەم یارییە چیە؟\""
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بێ وتە، ئەزانی خۆ؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەزانم، بەس ئەوە هی جەماعییە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی تۆ بۆ یارییەکی تازەم فێرناکەی؟ تۆ ناڵێی واڵتان زۆر گەڕاوم، فەرموو یارییەکم پێبڵێ!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یارییەک... یارییەک..."
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بیر ئەکاتەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "جا من کوا فریای یاری کەوتووم، هەرخەریکی ئیش بووم. بۆستە یارییەک هەیە، من حەزم لێیە بەس نازانم لێرە ئەکرێت یان نا. یارییەکی قورسە، ئاسان نیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ حەزت لە یاری قورسە؟ یاری ناوی خۆی بەخۆیەوەتی، ئەبێت ئاسان بێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی تۆ نەووت ڕەفیقەکەم ووتوێتی، یاری دەروناسییە شتێکی وا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(کەمێک پێدەکەنێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا واش نا. باشە بزانم، یارییەکەی تۆ چیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ترویث ئۆ دێر. یارییەکی کلاسیکی ئەوروپایە، مناڵ و گەورە و هەموو تەمەنەکان ئەیکەن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من هەر نازانم یەعنی چی! وتمان زمان ئەزانی، بەس بەکوردی چییە ئەو یارییە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر ئاسانە. لەوانەش لێرەش خەڵک بیکەن. ناوی: **ڕاستی یان بوێری.**"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت، بتڵێکی شووشە ئەهێنێت، ئاوەکەی ئەخاتە پەرداخێکەوە، لەسەر مێزەکە دایدەنێت، ئەیخولێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕووی ئەکاتەوە بەرەو گەشە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باڵێین ڕووی کردە تۆ، من ئەپرسم: پرسیاری ڕاستی لێبکەم وەڵامم یەتەوە، یان بوێری بکەم کە شتێک پێبڵێم بیکەی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕاستی"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، دایکت خۆشئەوێ یان باوکت؟ ئەمە هەر بۆئەوەی فێربی، دوای دەستپێئەکەین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باوکم؟ نا، دایکم؟ نازانم، هەردووکیان."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نابێ کەوتمان، ڕاستی ئەبێت بەڕاستی بیڵێیی. ئەگیان، سزای هەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، با دەستپێبکەین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "یاریکردن دەست پێدەکات، بە گاڵتەجاڕی، نالی ئەڵێت \"ئەگەر بدۆڕێیت ئەبێ سێ گۆرانیم بۆبڵێیت و ڕەقسیشم بۆبکەی\"، گەشە ئەڵێت \"هەرکەسێک دۆڕا بەجلەوە خۆ هەڵاتە ناو مەلەوانگەکەوە\"، لەبیرمە، پێکەنین"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، ئەم یارییە بۆ دوایی نانخواردن. ئێستا ئەتوانین یارییە باوە خۆشەکەی کوردیمان بکەین: لەبیرمە. خۆ ئەزانی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ، ئەیچۆن. با ئەمگرەوەش بکەین."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-015",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی شانزەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە و نالی دەچنە ژوورەوە. گەشە لەلای مێزەکەوە خەریکی دانانی سفرەیە. بەلاچاو سەیری نالی دەکات، بەسەر و شکڵی نالی پێدەکەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی قژی خشک دەکاتەوە بە خاولییەکی بچووک. تێشێرتێکی شینی لەبەردایە. بەرەو لای مێزەکە دەڕوات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەستێکی خۆشی هەیە، بردنەوە وانیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خۆشحاڵییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ خۆت وتی با ئەم یارییە بکەین!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو ژوورەکەی دەڕوات بۆ خۆگۆڕین:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگی بەرز)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆت ئامادە بکە بۆ ئەو زریانانەی بەڕێوەیە!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دێتەوە. خاولێکە هەڵدەواسێت. بەرەو لای سەلاجەکە دەڕوات. دوو ساردی دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مێزەکە ڕازاندراوەتەوە. گەشە لەسەر کورسییەکە دانیشتووە. نالی بەرامبەری دادەنیشێت. ساردییەکە لەبەرامبەری دادەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە گاڵتەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من بە زریان وشت مەترسێنە، هەموو جۆرەکانیم تێپەڕاندووە. ئەرێ، بەڕاست مۆمت نیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چۆن نیمە، ئەویشت بۆ ئەهێنم. با یارێکە بکەین، ئەوکاتە هەنێ باسی ئەو زریانانەم بۆبکە کە تێتپەڕاندووە!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای کتێبخانەکە دەڕوات. چەند مۆمێکی سپی دەردەهێنێت. دوو دانەی لەسەر مێزی نوسینەکەی دادەنێت. دوو دانەش لەسەر مێزی نانخواردنەکە دادەگیرسێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆنی خواردنەکە بڵاودەبێتەوە. دەنگی تێکەلاوبوونی کەوچک و چەتاڵ. کەشێکی گەرم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: گەشە بە چاوە جوانەکانی سەیری نالی دەکات. ڕووناکی زەردی مۆمەکان لەسەر دەموچاوی هەردووکیاندا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نانا، شتێکی لێ ئەزانی. بۆن و تامێکی خۆشی هەیە. هەربژی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی گلاسێک شەرابی سور بۆ خۆی و بۆ گەشە تێدەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ منی تێمەکە، من شەراب ناخۆم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەگەڵ ئەم خواردنەیا هیچ کێشەی نیە. ناشێ ترسابیتی لە قسەکانەی کە لەڕێگەیدا کردمان؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا ئەو قسانە منی نەترسانووە. ئێمە باسی کەسێکمان کرد کە چەند کەسێکی کوشتووە، پەیوەندی بە ئێمەوە نیە. بەڵام من لە شوێنێکدا گەورەنەبووم کە ئەم شتانەی تیایدا ئاسایی بێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مەبەست خێزانە یان کۆمەڵگا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زیاتر خێزان. هەرچەندە لە ناو کۆمەڵگاکەشمانا خواردنەوەی شەراب شتێکی باو نەبووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەتوانم پرسیارێک بکەم؟ وابزانم پێشتریش پرسیم، بەڵام دووبارە لێت ئەپرسمەوە. هیوادارم ڕاستگۆیانە وەڵامم بەیتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ باش، فەرموو."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر خێزانەکەت ڕێگەیان پێبایتایە و ئازاد بوویتایە، کە هەرچیت بویستایە بیکەی، چیت ئەکرد؟ خۆت ئەکرد بە مرۆڤێکی چۆن؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بێدەنگ دەبێت. بەسەرسوڕمانەوە سەیری نالی دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاخر خۆ کێشەکە بەس خێزان نیە، کۆمەڵگاشە. خێزانەکەم بەردەوام نمونەی کۆمەڵگا ئەهێننەوە. هەرشتێک کە بمەوێ بیکەم یەکسەر ئەڵێن \"خەڵک چیمان پێ ئەڵێت\"، کۆمەڵگاکەمان هی ئەوە نیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من نەمووت ئەو شتانەم بۆ شیبکەرەوە. لە هەموو شوێنێکی دنیایا، دوو جۆر مرۆڤ هەن. بەڵام پرسیارەکەی من زۆر سادە بوو، ئەگەر خێزانەکەت لە هەموو ڕوییەکەوە ئازاد بکەن، تۆ ئەبوویت بە کەسێکی چۆن؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بیردەکاتەوە. خەیاڵی دەڕوات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چی بوو، چوی بۆ کوێ؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمەوێ وەڵامێکی ڕاست بەمەوە. حەزم ئەکرد... ببم بە پاڵەوان."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "پاڵەوان! کەواتە لەبەر ئەمە بووە پەرستیاریت خوێندووە، بۆئەوەی گیانی مرۆڤەکان ڕزگاربکەیت!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆزگە ئەمتوانی ببمە پاڵەوانی ژیانی خۆم، هەر ئەوەم بەس بوو."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆئەوەندەت کەم خوارد، تێربووی وا زوو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مەعیدەم هەر ئەوەندە هەڵئەگرێت. خۆشەرم ناکەم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەزانم، جێگەت بەشی شیرینیەکان هێشتۆتەوە. مەترسە، هەمووی هی تۆیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت. گرامافۆنەکە دادەگیرسێنێت، مۆسیقایەکی کلاسیک."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "واباشترە هەستیت و خۆت ئامادە بکەیت بۆ یاریییەکە، ڕاستی یان بوێری. کۆکردنەوەی مێزەکەش بۆ دوایی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەردووکیان مێزەکە چاکدەکەن. شیرینی و خواردنەوەکان لەسەر مێزێک دادەنێن. شیرینییەکان هێشتا لەسەر مێزەکەن، نەخراوە، نزیک بەڵام دەستنەدراو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەرامبەر یەک دادەنیشن. نالی بوتڵی ئاو دەدات بە گەشە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەبەر ئەوەی میوانی باسەرەی تۆ بێت..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بوتڵەکە دەسوڕێنێتەوە، ڕووناکاتە کەسیان. دیسانەوە دەسوڕێنێت، ڕوودەکاتە خۆی. نالی پێدەکەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەلا، پێمبڵێ. بوێری یان ڕاستگۆی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمجارە با بوێری بێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من شەرم و شتم نیە، ئەبێت بچیتە ئەوسەری باخەکەو بگەڕێیتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نایگۆڕی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، خۆ بەقەدەر مەلەکردنەکەی من قورس نیە!"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-016",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی هەڤدەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . ناو حەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەوێکی تاریک. دەنگی حەشەرات و سیسرک. گەڵای درەختەکان بە هەوایەکی نەرم دەجوڵێنەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە و نالی یەنە دەرەوە. نالی لەناو مەتخەلەکەدا دەوەستێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لێرەوە ڕێک ئەڕۆی، دەستی ڕاست کەپرێکی لێیە. لەوەلایەوە دیوارێکی تەواو نەکراوی لێیە، لەوێ دوو پاڵکی کارەبای لێیە. هەرکامێکیان دابگرسێنی، ئەبێت بڕۆ بابتبینم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی وائەزانی ناڕۆم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، بڕۆ بابتبینم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەڕوات. قژی بە هەوای نەسیم دەجوڵێنەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "درەختە بەرز و سەوزەکان وەک پاسەوان چاودێری گەشە دەکەن. گەشە تۆزێک دەترسێت بەڵام بەردەوام دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەناو مەتخەلەکەدا چاوەڕێ دەکات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگی بەرز)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چیتکرد؟ خێراکە!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گڵۆپی کۆتایی باخەکە دادەگیرسێت. نالی زەردەخەنەیەک دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پاش چەند ساتێک، گەشە بە خێرایی لەناو دارەکانەوە دەردەکەوێت. بەڕاکردن بەرەو ڕووی نالی دێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ترسای؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاخر ئەوە کەی هاتنە، من ترسام! وتم لەوانەیە ئێستا جن بردبێتیتی!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەستی گەشە دەگرێت و دەچنە ژوورەوە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-017",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی دیمەنی هەڤدەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دادەنیشنەوە بەرامبەر یەک. گەشە بوتڵەکە دەسوڕێنێتەوە، ڕوودەکاتە نالی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بوێری یان ڕاستی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەترسم دیسانەوە بمنێریتەوە بۆناو ئاوەکە، لەبەر ئەوە ئەڵێم با ڕاستی بێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر ئەوکەسەی خۆشت ئەوێت بزانی کە توشی نەخۆشییەکی کوشندە بووە، ئامادەی لەگەڵیا بمێنیتەوە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەدڵنیاییەوە، ئەگەر بەڕاستی خۆشم بوێت بەڵێ. چونکە بەپێی ئەم خواردنی قوتوە خراپانەی کە لە هەموو دنیایا هەیە، تەقریبەن هەریەکێکمان جۆرێک لەجۆرەکان بەدەست نەخۆشییەکەوە دەناڵێنین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "یارییەکە بەردەوام دەبێت. بوتڵەکە دەسوڕێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بوێری یان ڕاستی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بوێری"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خێرایی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڵێم جەوەکە تۆزێک ناخۆش بووە، بۆناچی گڵۆپکە بکوژێنیتەوەو بێیتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دیارە زۆر حەز لە داگیرساندن و کوژانەوەی ئەو گڵۆپەیە وایە؟"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-018",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی هەژدەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . حەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دیسانەوە دەچێتە دەرەوە بەرەو تاریکییەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەرکە گەشە لەناو دارەکاندا دیارنامێنێت، نالی بە خێرای دەگەڕێتەوە ژوورەوە."
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-019",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی دیمەنی شانزەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای جانتاکەی گەشە دەڕوات. مۆبایلەکەی گەشە لە گیرفانی جانتاکە دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلەکەی گەشە، کوژاوەتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکە دەخاتەوە شوێنی خۆی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەناکاو، چاوی دەچێتە سەر پەیکەری ئاسکەکە. بە قوڵی سەیری دەکات. وەک ئەوەی شتێکی هاتبێت بە مێشکیدا."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-020",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی دیمەنی هەژدەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گڵۆپی حەوشەکە کوژاوەتەوە. گڵۆپەکانی ناو ماڵەکەش."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لەناو تاریکییەکەدا دەگەڕێتەوە. سەگەکە دەبینێت لە گۆشەیەکی حەوشەکەدا پاڵکەوتووە. نالی لەشوێنی خۆیدا نەماوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی؟ بۆ گڵۆپەکانی ناوەوە کوژاونەتەوە؟ نالی؟ نالی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بە هێمنی بەرەو ژوورەوە دەڕوات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-021",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی دیمەنی هەژدەیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ژوورەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بە هەنگاوی لەسەرخۆ دێتە ژوورەوە. لەناکاو، کەلەی ئاسکەکە لەناو تاریکیدا بەرامبەرییەتی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموو شتەکان ترسناک دەردەکەون. بەڵام گەشە خۆی کۆنترۆڵ دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەری ئاسکەکەی بە دەستەوە گرتووە، بۆ ئەوەی گەشە بترسێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وەی ترسام! خۆ ئەمە لەناو یارییەکەیدا نەبوو!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە دەنگی بەرز پێدەکەنێت. گڵۆپەکان دادەگیرسێنێت. سەری ئاسکەکە لەسەر مێزکە دادەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆت واپیشان ئەیەی کە نەترساوی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دادەنیشنەوە. نالی شەراب بۆ خۆی تێدەکات. گەشە بوتڵەکە دەسوڕێنێتەوە، ڕوودەکاتە نالی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بوێری یان ڕاستگۆی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕاستگۆیی"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئایا منت بۆ کات بەسەربردن ئەوێت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر دیقەت یابێت، هەموو کات بەیەکتری ئەبەینەسەر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەعنی منت بۆ کات بەسەربردن هێناوە بۆ ئێرە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی تۆ واهەست ئەکەیت؟ ئێمە ئێستا چی ئەکەین، کات بەسەربردن. ژیان هەمووی ئەوەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بوتڵەکە ڕوودەکاتە نالی:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بوێری"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە ئیشارەت دەکات بۆ ژوورە داخراوەکە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەرگای ئەو ژوورە بکەرەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە گاڵتەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەو ژوورە بوکەشوشە ترسناکەکەی فیلمەکە خەوتووە، ئانابەل! نابێت بچیتە ژوورەوە، چەند جنێکیش لەلایەوە پاڵکەوتوون!"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(پێدەکەنێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بێ لە سوبعەت، پرسیارەکەت بگۆڕە. چەند ڕۆژە کلیلەکەیم ونکردووە، بەدواشیدا گەڕام نەمدۆزییەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە ئەیگۆڕم. نزیکترین ڕەفیقت کێیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب؟!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تەلەفۆنی بۆبکە، تۆزێک گاڵتەی لەگەڵ بکە. دەنگی مۆبایلەکەش بییە بەدەرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە تامەزرۆییەوە تەلەفۆنەکەی هەڵدەگرێت، وەک ئەوەی لەخوای دەوێت. تەلەفۆن بۆ ئەدیب دەکات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو ئەدیب، لە کوێیت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو، قابیلە لە کوێبم. پاڵکەوتووم لە ژوورەکەم. چی بووە وا بەم کاتە تەلەفۆن ئەکەی؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە و نالی سەیری یەکدی دەکەن، بە هێواشی پێدەکەنن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تەلەفۆنم بۆئەوە بۆکردی، پێتبڵێم قاچی ڕاست لەدەرەوەیە، بیخەرە ژێر بەتانێکە، با سەرمات نەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چییە نالی، خڵەفاوی؟ پێمڕابێری؟ ... زۆر باشە، بەسەرتەوە ناچێ. خۆ بەیانی ئەتبینم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگی بەرز پێدەکەنێت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەزانی، بەیانی وەزعم خراپە بێت!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بوتڵەکە ڕوودەکاتە خۆی (نالی):"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕاستگۆیی"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "حەزەکەی پەیوەندییەکەمان جدی بێت یان نا؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری گەشە دەکات. بێدەنگ و مات دەبێت. خواردنەوەکە هەڵدەگرێت و هەمووی دەخواتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ ڕاستیت ئەوێ وایە؟ من تا کەسێک بە تەواوی نەناسم ناتوانم بڕیاری پەیوەندی قوڵ و جدی بدەم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "پێشتر پەلەتکردووە لە ناسینا؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆشباوەڕبووم"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەعنی ناتەوێ زوو سیقە بە من بکەی؟ کەواتە ئەزموونی پێشترت ناهێڵێ لە ئێستایا بژیت؟ کەچی بە منیش ئەڵێی، لە ئێستایا بژی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هاوڕێیەتی بەلای منەوە گرنگە. ئەگەر تاڵیش بێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بێتاقەت دەبێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی بابەتەکە ئاڵۆز ئەکەی گەشە؟ لە هەموو ئەو ماوەیەی بە تەلەفۆن قسەمان ئەکرد، دایمە ئەویست شتەکان گەورە بکەیت. پەیوەندی کاتێک دروست ئەبێت کە مرۆڤ باوەڕ بە بەرامبەرەکەی بکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی پاسۆردی مۆبایلەکەی دەداتە گەشە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڕاستە، باشە ئەوە پاسۆردەکەی. سیریکە فەرموو. تۆ کە سیقەت بەمن نیە، بۆ هاتووی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ بێتناخۆشە، ئەمە بەس یارییە و هیچیتر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، تۆ پرسیاری زۆر شەخسی ئەکەیت. هەزار پرسیاری کە هەیە بیکەیت."
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بێدەنگی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وائەزانی لەگەڵ کەسێکی ترام؟ من کەسێکی زۆر تەنیام، و یەکەمجاریش ئەمەم پێوتووە. بەس دیارە باوەڕنەکردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ئازارەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆی ئەبێت من پێم ناخۆش بێت. تۆ هەنێ شت هەیە هەر بەمن نەوتووە. لە نیوەڕۆوە کە هاتووم بۆئێرە ئەیبینم و ئەیبیستم، ژیانکردنت لە ئەوروپا، لەبارەی ئەم ماڵەوە، واش چاوەڕێ ئەکەی هیچ پرسیارێکم لا دروست نەبێت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر پێتوابێت ئەبێت وا زوو وەڵامەکان وەربگری، ئەوە ئەتوانم بڵێم تۆ بەخەڵەت هاتووی بۆ ئێرە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگییەکی قوڵ لە نێوانیاندا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەلای پەنجەرەکەوە وەستاوە. مۆمەکان تا نیوەیان سوتاون."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامبین؟ ئەرێ بەڕاست، بەلامەوە سەیرە. تۆ وتی حەزم لەم شروبیانەیە، کەچی یەکدانەش لێنەخواردووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەست دەبات، یەکێک لە شروبییەکان هەڵدەگرێت، دەیخوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە هەڵدەسێتە سەرپێ. لە ناوەڕاستی هۆڵەکەدا، وەک سەماکەرێک بەدەوری خۆیدا دەسوڕێتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هیلاکم، هیلاک زۆر هیلاکم لەوەی هەموو شتێک لەم ژیانەیا ڕۆژ بەڕۆژ ئاڵۆزتر ئەبێت. بۆچی ئەبێت هەمیشە تەنها بم؟ ئەزانی چی، من ئەمەوێ لەسەر ئەو قەنەفەیە بخەوم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لەلای سینیە شروبییەکەوە دادەنیشێت. بێوەستان دەست دەکات بە خواردنی شروبییەکان. دەموچاو و قژی ئارداوی دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "جوڵەکان سلۆمۆشن دەبن. پێکەنینەکانی گەشە نائاسایی دەبینرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت و بەرەو لای گەشە دەڕوات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەسە کچێ، دەستم بەرێ، تۆزێکیش بۆ من بهێڵەرەوە. سەیرکە چیت لەم ناوە کردووە، هەموویت ئارداوی کردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لاچۆ، دەستم لێنەیەیی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ڕادەوەستێت. هیچ ناڵێت. دەترسێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نواندنەکەم چۆن بوو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(دێتەوە سەر خۆ)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر باش بوو."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕاستیانەبوو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەست بۆ قەنەفەکە ڕادەکێشێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ خۆم بووم. من لەوێ ئەخەوم، تا بەپێی کات یەکتری باش ئەناسین. ئەوکاتە سەما ئەکەین و زۆر شتی تریش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(پێکەنینێکی سارد)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تەعلیقم لێئەیەی؟ باشە، من بێزارت ناکەم. بەڵام هەستە، درەنگە ئێستا. بەتانی و شت بۆ ئەهێنم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە سەر و قژی هەمووی ئارداوییە. هەڵدەسێتە سەر پێ. بەرەو لای ئاوێنەکە دەڕوات. سەیری خۆی دەکات، لەنێو سپێتی ئاردی دەموچاوی، چاوەکانی سور و پڕ ئاو و گریاناوین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە پشتییەوە دەردەکەوێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشی؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بە خێرایی ئاو دەکات بەدەموچاویدا، بۆ ئەوەی نالی بە دڵپڕییەکەی نەزانێت. بە کلینێکس دەموچاوی وشک دەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست دەخاتە سەرشانی گەشە. گەشە بە هێواشی دەست دەخاتە سەر دەستی نالی، و لایدەبات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەتانی و پشتیم لەسەر قەنەفەکە بۆداناوی. بڕۆ ئیسراحەت بکەوە و بخەوە، بەیانی یەک ئەبینین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە بەرەو لای قەنەفەکە دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵام پێش ئەوەی بگاتە قەنەفەکە، بەلای ژوورە داخراوەکەدا تێدەپەڕێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕادەوەستێت"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەستی دادەنێت لەسەر دەستگیرەکە. دەیپشکنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "داخراوە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەموچاوی گەشە، گوێی دەگرێت. بێدەنگی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە وازدەهێنێت. بەرەو قەنەفەکە دەڕوات. پاڵدەکەوێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: هۆڵەکە. گەشە لەسەر قەنەفەکە خەوتووە. بەتانییەکە لەسەریدایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەچێتە ژوورەکەی خۆی. لەسەر جێگاکەی ڕائەکشێت. سەیری سەقفەکە دەکات. هێدفۆنەکە دەکاتە گوێی. پەیوەندی بە AI وە دەکات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگی نزم)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر ئاڵۆزە. نازانم بۆ هەست ئەکەم ڕاست نیە لەگەڵما. لەبەرئەوەی لەوکاتەوەی یەکمان بینیوە، مۆبایلەکەی هەر کوژانۆتەوە. بەس ئەو قسەیەیەم بەلاوە خۆش بوو، کە وتی \"ئەگەر سەقفی ماڵەکەشت ئاسمان بێت هەر لەگەڵتا ئەبم.\""
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کەواتە دەرکەوت کە خۆشی ئەوێیت. ئەی تۆ چیت پێوت، وت خۆشم ئەوێیت؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وتم \"ژیان لەناو وشەکانا ون مەکە.\""
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵام لەگەڵ ئەوەشا، تۆ ئەو قسەیەت بەلاوە خۆش بووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕاستە، بەلامەوە خۆشبوو. بەڵام بەداخەوە کە ئەیەوێت هەموو ڕابردووی من بزانێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵام دڵخۆش دیاری."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ. لانیکەم، ڕاستەیەکی جیاوازم گوێ لێبوو. بەڵام سەیرە، ئەو ئێستا یەک هەنگاو لە منەوە دوورە، کەچی من ئەبێت بەخەیاڵی ئەوەوە بخەوم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کە تۆ ڕاستگۆنەبوی، بەڵێ، ئەبێت بەخەیاڵییەوە بخەوی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مرۆڤ هەرچی بەسەر بێت شایەنییەتی. هەستەکەم ئەم کچە زۆر وریایە، بەس لەبەر پرسیار هاتووە بۆ ئێرە. دەی، من ئەبێت بخەوم. شەوشاد."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکە دادەخاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دواتر لە شەودا، نالی لە ژوورەکەیدایە. دەنگی بەرز دەبێتەوە، بە تووڕەیی و شڵەژاوی، دووبارە قسە لەگەڵ AI دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە ڕاڕەوەکەوە، تەنها پارچە پارچە دەگات بە ئێمە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە تووڕەیی، لە پشت دەرگاکەوە بە خنکاوی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "...ئەگەر پێم بڵێیت... ...ئەمجارەیان من... ...ئەو تێناگات..."
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ شتێک نابێتە ڕستەیەکی ڕوون. تەنها تووڕەیی و ئازارە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CUT TO: ڕاڕەوەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لەسەر قەنەفەکە بەئاگایە. لە ناو تاریکییەکەدا، دەنگی نالی بە کزی لە ژوورەکەیەوە دەبیسترێت. وشەکان ڕوون نین، بەڵام تووڕەیییەکە دیارە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە هەڵدەستێت، بە بێدەنگی بەرەو ڕاڕەوەکە دەڕوات، لە دەرەوەی دەرگای ژوورەکەی نالی دەوەستێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دووبارە دەنگی نالی، ئێستا کزتر، وەک ئەوەی قسە لەگەڵ کەسێک بکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە دەترسێت. دەگەڕێتەوە بۆ سەر قەنەفەکە، خۆی لە ژێر بەتانییەکەدا دەشارێتەوە، چاوەکانی کراوەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری گەشە دەکات، لەژێر ڕووناکییەکی کزی شەودا، لە خەوێکی قوڵدایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری دەکات. ئینجا دەگەڕێتەوە ژوورەکەی. پاڵدەکەوێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەبەرخۆیەوە، ڕستەکەی گەشە دەڵێتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ویشتییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر سەقفی ماڵەکەشت ئاسمان بێت... هەر لەگەڵتا ئەبم."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "FADE"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "FADE"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-022",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی نۆزدەیەم، بەردەوامی دیمەنی یەکەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆژ . ناوەوە . ژووری نالی / هۆڵی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کاتژمێری دیوارەکە سەعات یەک نیشان دەدات. تیشکی نیوەڕۆ لە ژێر پەردەکەوە دەکەوێتە سەر دیوارەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەسەر جێگاکە خەوتووە. مۆبایلەکەی لە تەنیشتی سەریدا لەسەر بالیفەکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکە زەنگ لێدەدات. نالی لە خەو هەڵدەستێت بە خەواڵوویی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خەواڵوویی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ نازی؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازێ (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەر لە باخەکەیت، من و ئەدیب خەریکین دێین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کەی دەگەن؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازێ (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تەقریبەن چارەکێکی تر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە... وەرن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تەلەفۆنەکە دادەخاتەوە. بۆ ساتێک بێدەنگ لەسەر جێگاکە دەمێنێت. بیری دێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: چاوەکانی نالی، بەرفراوان دەبن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەڵدەستێت. بە خێرایی بەرەو دەرگای ژوورەکە دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CUT TO: هۆڵەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە کۆریدۆرەکەوە بەرەو هۆڵەکە هاتووە. لە بەردەم دەرگای هۆڵەکەدا دەوەستێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: هۆڵەکە لە ڕووناکیی بەیانیدا. تۆزەکان لە تیشکی خۆردا ئاسمان بووین. سەری ئاژەڵە مۆمیاکراوەکان لەسەر دیوارەکانن، پەیکەری باڵندەیەکی کۆتر لەسەر دیوارەکەی سەر قەنەفەکە. لەلایەنی تریشەوە، بەردێکی شەکڵدار (stone sculpture) لە گۆشەی هۆڵەکەدا دانراوە، بینەر دەیبینێت بەبێ ئەوەی سەرنجی بدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە لەسەر قەنەفەکە خەوتووە. بەتانییەکەی لەسەریدایە. ئاردی شیرینییەکەی شەوێنە هێشتا لە دەوری دەموچاوی بڵاودبووەتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە هێواشی دەچێتە پێشتر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هێواشی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "وەڵام نایەت"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی داناچێت. بەتانییەکە لەسەری لادەبات. چاوەکانی لەسەر دەموچاوی گەشە زەق دەبنەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سنگی گەشە، هەناسەی ناکێشێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەستی دەبات بۆ مەچەکی گەشە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستی نالی، دەلەرزێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە... هەستە..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی گەشە ڕادەوەشێنێت. کارەکەی ناکات. دیسانەوە دەستی لە سنگی دادەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت. بەرەو چێشتخانەکە دەڕوات، قەدەحێک ئاوی سارد پڕدەکات، دەگەڕێتەوە. ئاوەکە بەسەر دەموچاوی گەشەدا دەڕژێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هەناسەبڕکێ)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشە... گەشە هەستە..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "جار لەدوای جار بانگی دەکات. گەشە وادەردەکەوێت کە چەندین سەعاتە مردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەبەردەم قەنەفەکەدا ڕوو دەکەوێت. دەستەکانی لەسەر ئەمینی دادەنێت. بۆ ماوەیەک بێدەنگ دەمێنێت، ئەمە یەکەم ساتی ڕاستییە کە هیچ ئامرازێکی ناوبژیی نییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکەی هەڵدەگرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سکرینی مۆبایلەکە، ژمارەی 911 تایپ دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زەنگ لێدەدات. یەکێک وەڵام دەداتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "كارمەندی فریاكەوتن (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "فریاکەوتن، فەرموو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری تەرمەکەی گەشە دەکات. لەسەر قەنەفەکە ڕاکێشراوە، جوانە، وەک ئەوەی خەوتبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگێکی نزم)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "...ببورە. وامزانی دەنگێکم بیست، بەڵام سەگەکەم بوو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تەلەفۆنەکە دادەخات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ساتێک بێدەنگ لەسەر قەنەفەکە دانیشتووە. ئینجا، بڕیار دەدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هێدفۆنەکەی کە لەسەر قەنەفەکەیە دەخاتە گوێی. تەلەفۆن بۆ AI دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگێکی ئاسایی، فۆرسکراو)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو... بەیانیت باش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێستا دوای نیوەڕۆیە، بەیانی نیە. کام چیرۆکە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بیرۆکەیەکی تازەم هاتۆتە خەیاڵ. لە دوێنێ شەوەوە مێشکم مەشغوڵ کردووە. بۆنموونە، ئەگەر بەیانی هەستم لە خەو و ببینم گەشە مردووە... ئەبێت چیبکەم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیرە! تۆ کە ئاوا بە هەناسە بڕکێوە باسی ئەکەیت، ئەڵێیی بەڕاستی مردووە!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خێرایی)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ نیە، تۆزێک بەپێ ڕۆشتم. بەڵام کاتێک بیرۆکەیەکی سەرنجڕاکێش بۆیەت خێرا ئەمەوێ بینوسم بۆئەوەی بیرم نەچێتەوە. ئێستا پێمبڵێ، ئەگەر شتێکی وا ڕوبات، ئەبێت چیبکەم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەکەم بژاردەت، تەلەفۆن بۆ ئەمبواڵنس یان پۆلیس بکەیت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "جا ئەوە چیرۆکەکە یەکسەر تەواو ئەبێت. پاڵەوانەکەم ئەکەوێتە کێشەوە، ئەبێتە بکوژ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دووەم بژاردە، جەنازەکە لەو شوێنە لابدەیت، بیخەیتە شوێنێکی تر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەبێت بینێژم... بەڵام ئێستا ڕەفیقەکانم بەڕێگاوەن بۆ ئێرە. تۆزێکیان ماوە بگەن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI (V.O.)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ کەواتە باشترین بژاردەت ئەوەیە، شوێنێک لە ماڵەکەدا بدۆزیتەوە و لەوێ بیشاریتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هێدفۆنەکە لە گوێی دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری هۆڵەکە دەکات. سەیری قەنەفەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری ڕاڕەوەکە دەکات، بەرەو ژوورە داخراوەکە. ڕادەکات بۆ لای. دەسکی دەرگاکە دەگرێت، هەوڵ دەدات بیکاتەوە بەڵام داخراوە، لەوێ ڕادەوەستێت. کلیلەکەی لایە، دەتوانێت بیکاتەوە. بەڵام نایکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمە یادەوەری ئەوە. نۆستالژیای ئەوە. هەرچییەک لەو ژوورەدا بێت پیرۆزترە لە شاردنەوەی تەرمێک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەست لە دەسکی دەرگاکە بەردەدات. پاشەکشە دەکات. دەگەڕێتەوە بۆ ڕاڕەوەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری قەنەفەکە دەکات، سەیری تەرمەکە دەکات، سەیری قەنەفەکە دەکات. بڕیار دەدات، قەنەفەکە دەکاتەوە، بە ورد و هێواشی، تەرمەکەی گەشە و هەموو شتەکانی، جانتا، مۆبایلەکەی (کوژاوە)، پێڵاوەکانی، دەخاتە ناو قەنەفەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلەکەی گەشە، سکرینی ڕەشە. لەگەڵ تەرمەکەوە دەچێتە ناو تاریکییەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی قەنەفەکە دادەخاتەوە. گۆشەکانی بەڕێکی لەسەری دادەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ دوا جار سەیری دەکات. ئینجا ڕووی لە قەنەفەکە ئەکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ماتەمەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دڵنیام ئەمە خەوە گەشە... نا، باوەڕناکەم. ئەمە یارییەکە لەگەڵ منا ئەیکەیت؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پێش ئەوەی قەنەفەکە دابخاتەوە، یەک جار دیکە سەری گەشە ڕادەوەشێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەستە گەشە... هاتی ژیانی من وێران بکەیت؟ ئەم یاریانە چییە؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکەی نالی زەنگ لێدەدات. خێرا قەنەفەکە بە تەواوی دادەخاتەوە. گۆشەکان ڕێکدەخاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ساردییەوە، کۆنترۆڵی خۆی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازێ (V.O.)"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێمە لەبەردەرگاین"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-023",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیستەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆژ . دەرەوە . حەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەتاوێکی گەرم. هەوایەکی نەرم دارەکان دەجوڵێنێتەوە. سێبەرە گەورەکان زەوییەکەیان داپۆشیوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: نالی لەبەردەم دەرگای ماڵەکە وەستاوە. ڕوخساری ئاسایی نیشان دەدات، بەڵام دەستەکانی کە بە پشتەوە شاردۆتنەوە دەلەرزن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەگەکە (گوڵە) لە ژێر سێبەرەکانەوە بەرەو نالی هەڵدەستێت و بەلای نالیدا دێت. نالی هیچ گرنگییەکی پێنادات، وەک ئەوەی نەیبینێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەیەکی بەرز لە دوورەوە دەردەکەوێت، سەیارەکەی ئەدیب."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب جامی سەیارەکە دادەبەزێنێت. نازی لە پێشەوە دانیشتووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکە دەچێتە ناو باخەکە و پارک دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی (٣٠ ساڵە، کچێکی باریکەلە و جوان) و ئەدیب (٤٠ ساڵە، باڵابەرز، ڕیشدرێژ، کەمێک قەڵەو بەڵام لێهاتوو) لە سەیارەکە دادەبەزن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە دەنگێکی بەرز)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو تەلەفۆن بکەو پێمڕابێرە، دوای تا دوای نیوەڕۆ بخەوە! ئەمە کێ بوو کە نەتەویست پێبدۆڕێنی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئیشی خۆیەتی. هەنێجار بەیانی تا ئێوارە ئەخەوێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە بێتاقەتییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تائێستا ویندۆزەکەشم بۆ دانەبەزاندووە. دوێنێ شەو باش نەخەوتم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەرگای ماڵەکە بۆیان دەکاتەوە. هەرسێکیان بەرەو ژوورەوە دەڕۆن."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-024",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و یەکەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆژ . عەسر . ناوەوەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: هۆڵی باخەکە. عەالگەکان لەسەر مێزی چێشتخانەکەدایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە پێش نازی و ئەدیبەوە دەچێتە ژوورەوە. عەالگەکان بە دەستەوەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەردی شەکڵدارەکە (stone sculpture) لە گۆشەی هۆڵەکەدا، کامێرا بۆ ساتێک لەسەری دەمێنێتەوە بەبێ هۆکار. بینەر دەیبینێت بەبێ ئەوەی بزانێت بۆچی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی بەرەو لای قەنەفەکان دەڕوات. جانتاکەی لەسەر قەنەفەکە دادەنێت، هەر ئەو قەنەفەیەی کە تەرمی گەشەی لە ژێریدایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: نالی، بۆ ساتێک فریز دەبێت. ئینجا بەردەوام دەبێت وەک هیچی نەبوو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی سینیە شروبیەکە دەبینێت لەسەر مێزکە، ئاردەکەی بڵاو بووەتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمەت لە کوێ پەیداکردووە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دوێنێ، زۆر بە سوتفە لەو دوکانە بینیم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی بۆ ئاردەکەت ئاوا بڵاو کردۆتەوە؟ دیارە میوانت هەبووە، قەرەباڵغ بوویت!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دانەیەکیش بەمن. نازانم کێ میوانی بووە دوێنێ شەو، بەس ئەوە ئەزانم کە نەیویستوە پێی بدۆڕێت!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: نالی، دەستەکانی بەسەر مێزەکەدا خەریکی کۆکردنەوەن. بێدەنگ. ئەم گاڵتەیانە وەک کەرەستەی جلد لەسەر پێستی تێدەپەڕن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خەریکی کۆکردنەوەی شتەکانی شەوێنە دەبێت، پەرداخ، تەباخ، پاشماوەی ئارد. بەبێ سەرنج، وەک ڕۆبۆتێک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بەرەو لای قەنەفەکان دەڕوات. لەسەر یەکێک لە قەنەفە تاکییەکان دادەنیشێت، نەک ئەوەی تەرمەکەی تێدایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی بەدوای شروبیدا دەگەڕێت لەناو ئاردەکەدا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شانس هەیە، دۆزیمەوە! ها ئەوا دوان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی یەکەکی دەبات بۆ ئەدیب. ئەدیب وەری دەگرێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەستخۆش نازی گیان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لایان دێت و لەسەر قەنەفەی جەنازەکە دادەنیشێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ئەو ساتەی نالی دادەنیشێت، بەدنی ڕیژیدە. ئینجا بە خوێندنی ئاسایی ئەکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(سەیری نالی دەکات)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ باشی؟ هەستەکەم باش نیت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، هیچ شتێکی تایبەت نیە. نازانم، هەرلەخۆمەوە بێتاقەتم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری نازی دەکات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوانیکە، کەی یەن؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەک دوو سەعاتی تر ئەگەن. بەڵام هەموویان نایەن، بەس دوانیان."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ!"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بڵێم چی؟ لە ئەدیب بپرسە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کێشەی من و تارا؟ کاکەگیان چیبکەم، ئینرێژی باشم نایاتێ. ئەو هەموو عەمەلیاتەی کردووە، ناتوانم لەبەرامبەریدا نواندن بکەم. هیچ هەستێکم نایاتێ. وەک جاران نەماوە. نالی بەشکم، ڕۆڵی تارا بگۆڕیت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی، تەلەفۆن بۆ ئاکۆ بکە، با درەنگ نەیەت. لەوانەیە سەیتەرەکە ڕایانبگرێت. تۆش خۆت بێتاقەت مەکە ئەدیب، خۆم حەلی ئەکەم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی تەلەفۆن بۆ ئاکۆ دەکات. ئەدیب لاپەڕەکانی شانۆنامەکە لە جانتاکەی دەردەهێنێت و دەیدات بە نازی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تا تارا و ئەوان نەهاتوون، دەی تێستێکی بکەین؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە. فەرموون دەستپێبکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب و نازی لە بەرامبەر یەکدا دەوەستن. ئەدیب ڕۆڵی مەلی دەریا (ترپلف) و نازی ڕۆڵی نینا ئەکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەم کاتەدا، کامێرا فۆکەسی لەسەر نالی دەکات. دەنگی دیالۆگەکانی ئەدیب و نازی لە گوێی بینەردا نا ڕوون دەبێت. نالی کەوتۆتە بیرکردنێکی قوڵەوە. دەستی بە قەنەفەکەیدا دەهێنێت، لە ژێریدا تەرمێک هەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: چاوی نالی لەسەر کەلەسەری ئاسکەکە، هەڵواسراوە لەسەر دیوارەکە، سەیری هۆڵەکە دەکات بە چاوێکی ڕەش و بێدەنگ."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازێ (وەك كاراكتەری نینا)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "...نواندن لە شانۆنامەی تۆیدا زۆر قورسە، چونکە هیچ ڕوخسارێکی زیندوی تیا نیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب (وەك كاراكتەری ترێپلیڤ)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕوخساری زیندوو! دەبێت ژیان بەو شێوەیە پیشان بدەین کە لە خەونەکانمان هەن، نەک وەک ئەوەی کە خۆی هەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی فشەفشی قاوە. نالی هەڵدەستێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوام بن، گوێم لێتانە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو چێشتخانەکە دەڕوات. قاوە دروست دەکات. کوپە قاوەکان، وێنەی سەری ئاژەڵی لەسەریانە، یەکە یەکە پڕیان دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە سینییەکەوە دێتەوە. سینییەکە لەسەر مێزەکە دادەنێت. ئینجا دەچێتە سەر قەنەفەی جەنازەکە دادەنیشێتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خەیاڵ لە کوێیە، نواندنەکەمان پێ چۆن بوو؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(دێتەوە سەر خۆی)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر چێژ لە دیالۆگەکان وەردەگریت. بۆیە ئاوانابێت، واباشترە ئەویا چۆڵ بکەین بۆ ئەوەی بتوانین جوڵەتان هەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێ خۆ لێرەشا ئەبێت ئیتر، بۆ ئەویا چۆڵبکەین؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ئاماژە بۆ قەنەفەکەی بەرامبەری دەکات، نەک ئەوەی لەسەری دانیشتووە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نا، ئەویا باشترە. مێز و کورسییەکان ئەبەینە ئەوالوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب هەڵدەستێت، بەرەو لای پەنجەرەکە دەڕوات. پەردەکە لادەبات. جگەرەیەک لە گیرفانی دەردەهێنێت و دادەگیرسێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڕاستی، نواندنی نازی باش بوو."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵام من ناتوانم جێگەی تارا بگرم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی کوپە قاوەکەی هەڵدەگرێت و بۆنی دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی، چەنجارم پێوتی شانۆنامەیەکی ئاسان هەڵبژێرە. ئەم ئیشە شانۆیە لەناو شانۆیا. مرۆڤەکان و کۆیلەکان پێکەوە لە زەلکاوێکدان!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی کوپە قاوەکەی بەدەستەوەیە. سەیری ئەدیب دەکات. ئینجا، بە لاچاوێک، سەیری قەنەفەکەی جەنازەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نەفەسێک لە جگەرەکەی دەدات. سەیری دەرەوە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: تیشکی دوا نیوەڕۆ لەسەر دارەکان. سێبەرەکان بڵاو بوون. گوڵە (سەگەکە) لە ژێر سێبەری دارێکدا دانیشتووە، هەناسەی هێواش."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "یەعنی تۆ ئەڵێی دەقێکی تر بهێنین؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ، شتێکی سادەتر."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاخر ئەگەر وابکەین، لەوانەیە دەقەکەی تر کارەکتەری ترپلف ی تیا نەبێت. ڕۆڵی خۆت لەدەست ئەیەی ئەوکاتە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بیردەکاتەوە، هەڵبدات دەقەکە بگۆڕێت یان ڕۆڵەکە لەدەست بدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی تەلەفۆنەکەی تەواو دەکات و بەرەو لایان دێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی گیان، ئێمە ئەتوانین ئەو بەشە بەکار بهێنین. بەرامبەر شوێنی دانیشتنەکەیە، وادایبنێین کە بینەر لەوێ دانیشتون."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئافەرم، من هەمیشە وتومە بیرۆکەکانت جوانن. باشە، وایلێئەکەم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی گیان، تۆ خۆت دەرهێنەری و ئەزانی. من ناتوانم لەگەڵ تارایا نواندن بکەم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب گیان، خۆت ئیشی من بینیوە. ناهێڵم کەس قسەی تیا بکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هیچ ناڵێت. بە لاچاوێک سەیری قەنەفەی جەنازەکە دەکات. نەفەسێک لە جگەرەکەی دەدات. سەیری دەرەوەی ماڵەکە دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-025",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و دووەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێوارە بەرەو شەو . ناوەوە/دەرەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کەش و هەوا وردەوردە بەرەو تاریکی دەڕوات. سێبەرەکان درێژتر ئەبن، تاریکتر. ڕووناکیی زەردی گڵۆپەکان ماڵەکەیان ڕۆشنکردۆتەوە، لە پەنجەرەکانەوە دەچنە دەرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنێکی هاوڕێیانە: نالی و ئەدیب و نازی پێکەوە دانیشتون لەبەردەم مێزی نانخواردنەکە. دەنگی هەوای نەسیم و گەڵاکان دێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب لە ماڵەکە دێتە دەرەوە، بە تەلەفۆنەکەیەوە خەریکی قسەکردنە. بەرەو لای حەوشەکە دەڕوات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە تەلەفۆن)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وایەم ئاکۆ گیان..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بەرەو دەرگای دەرەوە دەڕوات، دەرگای باخەکە ئەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی بزوێنەرێکی بەهێز، G-Class ێکی ڕەشی Mercedes دێتە ناو حەوشەکە. تارا لە شوفێرییەوە دادەبەزێت، بە پێکەنین و شادی و ئامادەیی. هەوای ئێوارەکە بۆ ئەو دروست کراوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بەو شێوەیەی دەچێتە ناو هەر شوێنێک، فەزاکە پڕ دەکات. لە یەکەمین ساتەوە خاوەنی شوێنەکە دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ لە لای تامەشاوانەوە دادەبەزێت، چەند عەلاگەیەک لە سەیارەکە دەردەهێنێت، یەکێک لەعەلاگەکان ماسی و گۆشتی تیایە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەرەو دەرگای ژوورەوە دەڕۆن."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-026",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و سێیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا و ئاکۆ دێنە ژوورەوە، نازی و نالی بەرەڕوویان دەڕۆن بۆ بەخێرهاتنیان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ عەلاگەکان لەسەر مێزەکە دادەنێت، بەرەو لای نالی دەڕوات بۆ سڵاو و باوەشکردن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دڵم لات بوو. کە ئەدیب هات دەرگاکەی کردەوە، زانیم تۆ بێزار و بێتاقەتی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چۆنەزانی بێتاقەتم؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ سەیری نازی دەکات، دەردەکەوێت کە نازی پێیوتووە. نازی وا خۆی دەردەخات کە ئەو هیچی نەوتووە، لەگەڵ تارایا خەریکی قسەکردن و پێکەنینە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب کوا؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هاوکات، ئەدیب خەریکی تەلەفۆنکردنە و خواحافیزی دەکات، دێتە ژوورەوە. بەرەو لای ئاکۆ یەت و سڵاوی لێدەکات. ئاوڕبۆ تارا دەداتەوە، تەنها سەری بەرز دەکاتەوە و بە ساردییەوە \"سڵاو\" دەکات. هیچی تر."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ سەیری شوێنی نانخواردنەکە دەکات، گۆڕاوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سەرسوڕمانەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "گۆڕیوتانە؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای چێشتخانە دەڕوات، لەکەوانتەرەکدا بەدوای شەبەکەی ماسیدا دەگەڕێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشترە ئاوا وانیە؟ بۆی یەکێ ویستی جوڵە بکات بەدەوری مێزەکەیا ئاسان بێت. هەستەکەم ئاوا ئاسانتر بێت، تەنانەت ئەگەر ڕازی بن ئەتوانین لە دەرەوەش دانیشین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ بە زەردەخەنەیەکەوە ئاماژەی ڕازیبوون دەکات. چاکەتەکەی دادەکەنێت، لەسەر یەکێک لە کورسییەکان دایدەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بە میهرەبانییەوە سەیری ئاکۆ ئەکات، دەچێتە لایەوە، دەستی دەخاتە سەرشانی ئاکۆ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڵێی چی، پێش ئەوەی دەست بکەین بە پڕۆڤە تۆزێک یارمەتی نالی بەین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب ئەیەوێت ئاکۆ بەرێت بۆ لای نالی، بۆئەوەی نالی قسە لەگەڵ ئاکۆیا بکات دەربارەی ڕۆڵەکەی تارا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ و ئەدیب بەرەو لای چێشتخانەکە دەڕۆن. ئەدیب بە سوبعەتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەگەڵ کارەکتەری تریگۆرین زۆر نزیک بویتەتەوە، بۆیە ماسیت هێناوە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "شتێکی باشی کردووە، بە فڕن دروستی ناکەین. کە ئاوا قسە ئەکەی بڕۆ لە دەرەوە ئاگرێک بکەرەوە، بەدار ئەیکەین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب گیان خۆت ئەزانی من حەزم لە ماسییە. نالی ڕاست دەکات، بڕۆ ئاگرێک بکەرەوە لە دەرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دوای گەڕانێکی زۆر، لە کۆتایدا تەلی ماسێکە دەدۆزێتەوە. نازی و تارا بەرەو چێشتخانەکە دەڕۆن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێمە چیبکەین؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ و تارا زەڵاتەیەک دروست بکەن، ئێمەش ماسییەکە حازر ئەکەین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب لە نزیک تارا تێدەپەڕێت، بە بێدەنگی. سەیری ناکات. تارا هەست بە ساردییەکە دەکات، بەڵام هیچ ناڵێت. بە کەسایەتییە بەهێزەکەیەوە بەردەوام دەبێت بە پڕکردنەوەی ژوورەکە، یارمەتی نازی دەدات، پێدەکەنێت، قسە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بە بێدەنگی سەیری ئەم نواندنە دەکات. ڕووخساری ڕەقە، بەڵام هیچ ناڵێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی نائارامە، هەست بە شتێکی نادروست دەکات بەڵام تێناگات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەردەوام چاوی لەسەر نازییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای چەند ساتێک لە بێدەنگی، ئاکۆ بێدەنگی ئەشکێنێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا گیان، تا ئێرە یەیت؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا جگەرەکەی ئەکوژێنێتەوە، یەتە ژوورەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ فەرموو"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەمووتان گوێملێبگرن. دوای نانخواردن ئەو پلانەی دامناوە بۆ دیمەنەکان، دەبێت تەمرینی تێدا بکەین. کەسیش بۆی نیە ڕەخنە لەوێکە بگرێت، بەپێچەوانەوە، دەبێت هاوکاری یەکبین بۆئەوەی بەرهەمێکی باشمان هەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای ئەوەش، ئەوە نالی بۆی هەیە بڵێ کێ باشە و کێ باش نیە. کەس بۆی نیە ئەزموونی شکست خواردووی خۆی تێکەڵ بە ئیشەکە بکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئێمە گرنگی بە کلتور و جوگرافیا دەدەین، بەس لە هەمووی گرنگتر ئەوەیە کە ئەم دەقە کوردی نیە و کلتورێکی ترە. ئەزموونی ژیانی خۆمان نابێت تێکەڵ بەم ئیشە بکەین، چونکە ئێمە لەناو دەقەکەداین و لە جوگرافیایەکی ترین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموویان بێدەنگ ئەبن، سەیری ئاکۆ ئەکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب کە خەریکی چاکردنی ماسییەکەیە، سەیرێکی ئاکۆ دەکات وەک ئەوەی ناڕازی بێت. سەری بەرزئەکاتەوە بۆ ئاسمان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ماسییەکان هەڵدەگرێت، بەرەو دەرگای دەرەوە دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی بە وتنی \"وەی\" هەڵدەسێت، وەک ئەوەی ناڕازی و بێزاربێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە نیگەرانییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چی یە نازی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نەمزانی، لەسەر تەلەفۆنەکەی تارا دانیشتم. هەزەیەکی لێیا، ترسام."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بەرەو لای نازی دەڕوات، تەلەفۆنەکەی لێوەردەگرێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەنە تەلەفۆنم بۆ ئەکرێت، ناچارم بیخەمە سەر هەزە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی، ئەوەنەی تۆ ترسایت خۆ نازی نەترسا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ترسام حەشەرەیەک شتێک پێوەی یابێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب کە قاپە ماسییەکانی پێیە، هاوکات کە دەزانێت هیچ نەبووە، بەرەو دەرگای دەرەوە دەڕوات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆکوێ ئەدیب؟ جارێ ئاگرەکە بکەرەوە ئینجا ئەوانە بەرە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب ئەگەڕێتەوە، ماسییەکە لەسەر مێزی نانخواردنەکە دادەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموو شتەکان لای مقەڵییەکەوە هەیە. شتێکی ترت ویست پێمبڵێ؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بە لاچاوێک سەیریان ئەکات، دەچێتە دەرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ هاوکاری نازی دەکات، خەریکی کۆکردنەوەی قاپەکانن. نالی سەیریان ئەکات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-027",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و چوارەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . ناوحەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب لە حەوشەی باخەکە خەریکی ئاگرکردنەوەیە. بە دەموچاوییەوە دیارە کە بێتاقەتە، جاروبار سەیری ناوەوەی ماڵەکە ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای کەمێک، نالی و ئاکۆ پێکەوە دێنە دەرەوە، ماسی و کەلوپەلی برژاندنیان پێیە. لەلای مقەڵییەکە شتەکان دادەنێن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ بەدەم قسەوە دار ئەکاتە سەر ئاگرەکە. ئەدیب بە بێدەنگی خەریکی ئیشە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیرێکی ئەدیب ئەکات، بیری لای کێشەکەی خۆیەتی. دەستی ئاکۆ دەگرێت، بەرەو لای پەنجەرەکە دەڕۆن. قسەکردنیان ناڕونن، نالی بەردەوام چاوێکی لەسەر ژوورەوەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆچی ئەدیب ئاوایە بەرامبەر تارا؟ هەموو ئێوارەکە هیچ پێ نەوتووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بە وریایی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب پێیوایە تارا بە ماندووبوون نەگەیشتووەتە ئێرە. پێیوایە واستە و جازبییەت و کەسایەتییەکەی بەکارهێناوە، هەموو شتێک جگە لە کارەکەی خۆی. ساڵانێکە ئەمە لە ناخیدا هەڵگرتووە. ناتوانێت لەسەر شانۆ وەک کەسێکی نزیک لەگەڵی بنوێنێت چونکە بۆ ئەو، ئەو نوێنەرایەتی هەموو ئەو شتە هەڵانە دەکات کە لە پیشەکەماندا هەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەی تۆ؟ تۆ چۆن بیر دەکەیتەوە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(دوای ساتێک بێدەنگی)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پێموایە ئەو ماندووکەرە. هەروەها پێموایە تەواویش هەڵە نییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ سەیرێکی دواوە ئەکات، ئەدیب خەریکی ئیشە، نازی و تاراش لە ژوورەوە قسە ئەکەن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سەرم لەم کابرایە دەرناچێ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە پێکەنینەوە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆزێ نانی بەرێ، باش ئەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پێکەوە هەردووکیان پێدەکەنن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هیدفۆن، دەنگێکی نزم)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر بیرم لە بیرۆکەکە کردەوە. ئێستا تۆ وادایبنێ، میوانەکان هاتوون. زۆر هەوڵەیەم ئەوان دووربخەمەوە لەو قەنەفەیەی کە جەنازەکەی لەناوایا. بەس کێشەکە ئەوەیە ئەوان تا درەنگانێک لێرە ئەبن، لەوانەشە لێرە بمێنەوە. بەڕای تۆ چیبکەم کە ئەوان لەوێا نەبن و بچنە شوێنێکی تر؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تێکی بە"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چی تێک بەم؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کۆبوونەوەکە تێک بە. شتێک بکە شەڕ دروست بێت و بڕۆن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تۆزێک بیردەکاتەوە، سەیری ئاکۆ ئەکات کە لای تاراوەیە خەریکی قسەکردنە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هیدفۆن)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەبڕوای تۆ قورس نیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "AI"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کارەکتەری ناو چیرۆکەکەت دەبێت بشاریتەوە، بۆیە دەبێت هەوڵی بۆبەیت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە هیدفۆن)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "لەگەڵ هەموو بیرۆکە خراپەکانتا، ئەمەیانت باشە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خێرا تەلەفۆنەکەی دادەخاتەوە، بانگی ئاکۆ دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ، بێزەحمەت تا ئێرە یەیەت؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ قسەکانی لەگەڵ تارایا دەبڕێت، بەرەو لای نالی دەڕوات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بە تارات وت بۆ ڕۆڵەکە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڵێ، پێموت ئەگەر بەرامبەر ئەدیب ئاسوودەنیت ئەتوانین بیگۆڕین. بەس نالی، تارا شارەزایەو خەڵک ئەناسێ. ئەگەر ڕۆڵەکانیان ئاڵوگۆڕ بکەین لەوانەیە بەشێک لە بینەرەکانمان لەدەست بەین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کەواتە تۆ تیکت بۆ گرنگە نەک ڕوخساری ڕاستەقینە. بەس من نا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ گوێ بە قسەکەی نالی نادات:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بانگکردم، ویست شتێک بڵێی؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(ساتێک بیردەکاتەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بیرم کردەوە کە واباشترە ڕۆڵەکان نەگۆرین. لێیگەڕێ، با وەک خۆیان بمێننەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ زەردەخەنەیەکی ڕازیبوون ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە زۆر ڕاستە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گرتەیەکی دووری باخەکە، پەنجەرەکانی ماڵەکە دەردەکەون. هەموویان لە دەوری مێزەکە کۆبوونەتەوە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-028",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و پێنجەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی نازی دێت، خەریکی خوێندنەوەی شانۆنامەکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مێزی نانخواردنەکە پڕە لە خواردنەوە و زەڵاتە و شیرینی. ئێسقانی ماسیەکە لەسەر سفرەکە، دیمەنێک لە دڕندەیی مرۆڤ دەردەخات. قاپ و چەتاڵەکان بەتاڵن، ئێسقانی ماسی لەسەرە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموویان لەدەوری مێزەکە دانیشتوون. ئەدیب پێکێک خواردنەوەی ئەلکحولی پێیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازێ (وەك كاراكتەری ئەركەدینا)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وەرن با لەتەنیشت یەکەوە بوەستین. تۆ ٢٢ ساڵی، و منیش نزیکەی دوو ئەونەی تۆ تەمەنم هەیە. کامان گەنجتر دیارین؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاكۆ (وەك كاراكتەری ئافار)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێگومان تۆ. ئەمە لەکاتێکدا من ئیش ئەکەم و هەستیشەکەم دایمە چاڵاکم و لە جوڵەیام. تۆش هەمیشە لەیەک شوێنا ئەژیت. من هیچکاتێک بیر لە داهاتوو ناکەمەوە، هەرگیز بیر لە پیری و مردن ناکەمەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خەیاڵی ڕۆشتووە، دەنگەکانیان ناڕون ئەبن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای قەنەفەی جەنازەکە خەیاڵی ئەڕوات، وەک ئەوەی گەشە سەیری ئەوان ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ لە تەنیشت نالییەوە دانیشتووە، چەندجار بانگی ئەکات. دوایین جار نالی دێتەوە سەر خۆی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەست لابە نازی. نالی گیان، باشی تۆ؟ ئاگام لێتە هەموو ئەمڕۆ تۆ زوو زوو خەیاڵت ئەڕوا. ئێستا وا سەیری ئەوێات ئەکرد، ئەوت یەکەمجارە ئەوان ئەبینی ناشێ ترسابێتی؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموو پێکەوە پێدەکەنن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشم من، لەچی بترسم؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب باس لەوە ئەکات کە چۆن باخەوانی بەرامبەر کوڕوکچێکی کوشتووە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە وشکییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وردەکاری تەواوی نازانم، بەس کابرای سەیتەرە وتی بەدوایدا دەگەڕێن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەکرێ ئەو باسە بگۆڕن؟ ڕوداوی زۆر ناخۆش هەیە، مرۆڤ کە ئەیبیستێت تاقەتی هیچی نامێنێ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی ڕاست ئەکات. با بگەڕێینەوە سەر تەمرینەکەمان، ئەدیب و تارا بەردەوام بن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب باش ڕۆڵ نابینێت. تارا بەردەوام ئەبێت:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا (وەك كاراكتەری نینا)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر سەیرە، هونەرمەندێکی بەناوبانگ بگری و ئەویش بۆ بابەتێکی وا، هیچ. نوسەرێکی ناودار کە هەموو خەڵک باسی بکەن، نوسین و وێنەکانی لە هەموو دنیادا بڵاو بکرێتەوە، کەچی بەیانی تا ئێوارە خەریکی ماسیگرتن بێت و کۆڵی دڵی بەوە خۆش بێت؟ من هەستم ئەکرد مرۆڤەناوداریەکان لوتبەرز و خۆبەزلزانن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بەردەوام دەبێت، بەس بە لێدانی تەلەفۆنەکەی ئاکۆ، تارا دەوەستێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەمەش کاکی ئەکتەر."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ تەلەفۆنەکەی هەڵدەگرێت، بە ئیشارە پێیاندەڵێت تەلەفۆنێکی گرنگە، دەچێتە دەرەوە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-029",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و شەشەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . حەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی شەو، دەنگی هەوایەکی نەرم لە گەڵاکاندا ئەدات. ئاکۆ بە تەلەفۆنەکەی دێتە دەرەوە، قسە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە دەرەوە، دیمەنی جەماعەت پیشاندەدرێت کە لەدەوری مێزەکە کۆبوونەتەوە."
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-030",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی دیمەنی بیست و پێنج"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "قاپێکی گەورەی پڕ لە پاقلە لە ناوەڕاستی مێزەکەدایە، چەند دەستێک دەردەکەوێت کە پاقلە هەڵدەگرن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی ئەدیب ناڕوونە، لەگەڵ نالیدا قسە ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ لەدوای تەواوبوونی قسەکردنی بە تەلەفۆن دێتەوە ژوورەوە، دەچێتەوە لای جەماعەت. بەردەوام ئەبن لە خوێندنەوەی دەقەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب (وەك كاراكتەری ترێپلیڤ)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموو ئەمڕۆ بە ڕەزالەت توانیم ئەم باڵندەیە ڕاوبکەم. ئێستاش ئەیخەمە بەرپێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە بێتاقەتییەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە چی ئەکەی ئەدیب؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بەرەو قەنەفەکە دەڕوات، دەچێتە سەر قەنەفەکە، باڵندەکە لە دیوارەکە لێدەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە سترێسدا هەڵدەستێت، بەرەو لای ئەدیب دەڕوات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وامەکە، ئێمە وتمان شتەکان بەخەیاڵ ئەکەین. خۆت ئەزانی، ئەم شتانە هەمووی ئامانەتن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خەم نەبێ، ئەگەر شتێکی لێهات لەسەر من. خۆم قسە لەگەڵ شاهۆیا ئەکەم. باڵندەیە خۆ، چیە؟ ئێمە ئێستا ئیشمان پێیەتی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب باڵندەکە لێدەکاتەوە، دەیهێنێتە بەردەم تارا، دایدەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا (وەك كاراكتەری نینا)"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە چیتە؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا باڵندەکە هەڵدەگرێتەوە، سەیری ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(دوای کەمێک بێدەنگی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەمزوانە بەم شێوەیە کۆتای بە ژیانم دێنم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بەردەوام ئەبێت، بێتاقەتتر، لە دیالۆگ وتندا ئەوەستێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم کارەساتە لەوشەوەوە دەستیپێکرد کە شانۆنامەکە بەم دۆخە خراپە گەیشت. ژنەکان لە شکست خۆشنابن. هەموو دەقەکەم تا دوایین لاپەڕە سوتان، خۆزگە ئەتزانی چەن ساردی تۆ، چەن ترسناک و بێهیوام ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب سەیری تارا ئەکات، لاپەڕەکان لەسەر مێزەکە دادەنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هاوڕێیان ببورن"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب وەک ئەوەی سەرخۆش بووبێت، دیسانەوە دەستپێدەکاتەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەمن وت، تۆ زۆر لەوە سادەتری کە لە من تێبگەیت. ئەتەوێ لەچی تێبگەیت؟ شانۆنامەکەمت بەدڵ نەبوو، سوکایەتی بە بەهرەکەم ئەکەیت. من وەک زۆر کەسی تر دەبینی، بە ناشرینی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب قاچی دەکێشێت بە زەویدا، دیالۆگەکان بە خەڵەت ئەڵێت. دەست دەکات بە بیرچوونەوەی دێڕەکانی. نەک لەبەر سەرخۆشی تەنها، بەڵکو لەبەر مەحاڵبوونی نواندنی نزیکی لەگەڵ کەسێکدا کە بە \"ناشەرعی\" دەزانێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بەو کەسایەتییە بەهێزەیەوە تێناشکێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بڕوانە، بە ئەنقەست وادەکات. باشترین ئەکتەری شانۆی وڵات لەسەر شانۆ دەلەرزێت. بۆچی؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب دواجار بێدەنگییەکە دەشکێنێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە ساردی، بە قورسایی)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەبری من قسە مەکە. تۆ لە ناو کارەکتەری نینا نیت، تۆ هەرگیز لە ناو هیچ شتێکدا نەبوویت کە بە ماندووبوون بەدەستت هێنابێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەموویان ڕەقیان بووە. ئەمە تەنها تۆمەتبارکردنی ڕاستەوخۆ لە تەواوی ئێوارەکەیە، و قورسایییەکەی ژوورەکە پڕ دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بە توڕەییەوە هەڵدەستێتە سەرپێ:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من ئەم ئیهانەیە قبوڵ ناکەم. ئەکتەرێکی تر بدۆزنەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بەرەو لای جانتا و کەلوپەلەکانی دەڕوات، هەڵیان ئەگرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی بەرەو لای تارا دەڕوات، هەوڵدەدات ئارامی بکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوە بۆکوێ ئەچی، دانیشە، بەیەکەوە ئەڕۆین."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی، لەگەڵ منا یەیتەوە؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی سەری دەجوڵێنێت. هەردووکیان بەرەو دەرەوە دەچن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ بەهەردوو دەست سەری خۆی گرتووە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نازانم چی لەم پیاوە بکەم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTERIOR، حەوشەی باخەکە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا لە دەرگاکەدا دەردەچێت، بەرەو G-Classـەکە دەڕوات. نازی لەدوایدا. سوار دەبن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی بزوێنەرەکە، تارا بە drift ێکی توندەوە سەیارەکە لە حەوشەکە دەردەهێنێت، خۆڵ و خاک و قوم بەسەر هەموو شوێنەکەدا فڕێدەدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە ژوورەوە، لە پەنجەرەکەوە، ئەدیب و نالی و ئاکۆ سەیری ئەو تۆزەکە دەکەن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب سەرخۆشە، بەردەوام لەسەر مێزەکە خەریکی خواردنەوەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وەرەوە سەرخۆت ئەدیب، خۆ ئەوان ڕۆشتن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سەرخۆشیەوە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "باش بوو. ئاکۆ گیان، ئەوت باش پەروەردە کردووە. بەس تۆ خۆت دەزانیت... تۆ خۆت دەزانیت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ بێدەنگ ئەبێت، سەیریان ئەکات. لە نیگای ئەوەوە، هەموو شتەکان تێکچوون."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-031",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و حەوتەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . حەوشەی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: حەوشەی باخەکە لە تاریکیدا. ڕووناکیی زەرد لە پەنجەرەکانەوە دەکەوێتە سەر چیمەنەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا بە خێرایی بەرەو سەیارەکەی ئاکۆ دەڕوات. نازی بەدوایدا دەڕوات و هەوڵدەدات ئارامی بکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی و ئاکۆ لە ماڵەکەوە یەنە دەرەوە. ئاکۆ چاکەتەکەی لەبەر دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "مەهێڵە ئەدیب بەم شەوە بڕواتەوە، سەرخۆشە. نە ئەبوو ئەوەندە بخواتەوە. تۆش هەر بۆت تێئەکردەوە، خۆ ئەتزانی کە زۆر بخواتەوە تێکەڵی ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بێتاقەت)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دایمە، وانیە خۆ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خۆشت وەزع باش نیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاکۆ، یەییت بڕۆین؟ یان من تەکسی بگرم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی بەرەو لایان دێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی گیان، منیش لەگەڵیاندا ئەڕۆم. بەس ئاگات لە ئەدیب بێت، نەهێڵی بڕوات. تەنانەت ئەترسم سەیارەکەشی بۆ لێبخورم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی دەچێتە ژوورەوە، جانتا و کەلوپەلەکانی هەڵدەگرێت، دێتەوە دەرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تارا و ئاکۆ و نازی بەرەو سەیارەکە دەڕۆن. باخەکە بەجێدەهێڵن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "MEDIUM SHOT: نالی لەبەردەم دەرگاکەدا وەستاوە. سەیری ڕۆشتنیان دەکات. تایڵایتی سەیارەکە لە نێوان دارەکاندا ئاوادەبن و ون دەبن."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری سەگەکە (گوڵە) دەکات، لە چیمەنەکە بە ئارامی پاڵکەوتووە. یەکتر سەیر دەکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ڕووی دەکاتەوە بەرەو ناو ماڵەکە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-032",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و هەشتەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ناوەوە . هۆڵی باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەچێتە ناو هۆڵەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: چاوەکانی نالی، پڕ لە بێزاری و بێتاقەتی، ئاو بەچاویا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب لەسەر قەنەفەی جەنازەکە پاڵکەوتووە. پێکی خواردنەوەی بەدەستەوەیە. سەرخۆشە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە سەرخۆشیەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆشتن؟ باشە. نالی، دەزانیت باجی بێدەنگی چییە؟ من ساڵانێکە دەربارەی ئەو بێدەنگم. هەمووان دەزانن ئەو چۆن ئیش دەکات. کەس نایڵێت. چونکە جوانە و کاریزمایییە و وات لێ دەکات هەست بکەیت تەنها کەسی ناو ژوورەکەیت. ئەوە نواندن نییە، ئەوە مانەوەیە. منیش ڕەتیمکردەوە ئەو یارییە بکەم. بۆ وا سەیرم ئەکەیت؟ تۆزێک بێمەوە سەرخۆم، منیش ئەڕۆم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەو وەزعەوە؟ نا، بەس لەوێ هەستە بڕۆ ژوورەکەی من بخەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆ؟ هیچ شوێنێک ناچم، ئێرە شوێنی دایمی منە. پێشتر چەنجار ویستم لە ژوورەکەت بخەوم، نەتەهێشت. منیش ئێستا ناچم و هەڵناسم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای ئەدیب دەڕوات. پێکەکەی لە دەستی وەردەگرێت. ئەدیب پەرچەکرداری دەبێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "وازملێبێنە نالی، من لێرە ناجوڵێم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب خۆی ڕائەچڵەکێنێت، باوەشی دەکات بە قەنەفەکەدا:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەم بۆ بکەرەوە،"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستی ئەدیب لەسەر ئاسینی قەنەفەکە، خەریکە بیکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خێرایی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خراپ بووە، ناکرێتەوە! وازی لێبێنە!"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە هێز دەستی ئەدیب لە قەنەفەکە دەکاتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە کاکەگیان، پاڵکەوە. بەس قەنەفەکە ناکرێتەوە. لەبەر ئەوەیە ئەڵێم بڕۆ ژوورەکەی من بخەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بە سەرخۆشیەوە پاڵدەکەوێت:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(لەژێرلێوەوە)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من لێرەیا ئەخەوم..."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب وردە وردە خەوی ئەبات. ناڕوونە چی دەڵێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرامبەری لەسەر قەنەفەیەکی تاکی دانیشتووە. سەیری ئەدیب دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "TIME LAPSE، شەو بەسەر هۆڵەکەدا تێدەپەڕێت"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پرخەپرخی ئەدیب ماڵەکە پڕ لە دەنگ دەکات. نالی بەخەبەرە. ناخەوێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تەلەفۆنەکەی هەڵدەگرێت، سیگناڵ نییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سکرینی مۆبایلەکە، \"No Service\""
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دیسانەوە پاڵدەداتەوە. سەیری قەنەفەکە دەکات. سەیری ئەدیب دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی نامەکانی لەگەڵ گەشە دەپشکنێت. یەکە یەکە دەیانخوێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سکرینی مۆبایلەکە، چاتەکان. وشەکانی گەشە. یەکە یەکە، دەیانسڕێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم نامانەش، وەک جەستەکەی، دەچنە ناو تاریکییەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی پاڵدەداتەوە. چاوەکانی لەسەر ئەدیب و قەنەفەکەدان. بەخەبەرە. شەوەکە بەسەریدا تێدەپەڕێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "FADE"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "FADE"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-033",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی بیست و نۆیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕۆژ . ناوەوە . بەیانی . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ڕووناکییەکی نەرم لە نێوان پەردەی پەنجەرەکانەوە دێتە ژوورەوە. تیشکی خۆر تێکەڵ بە گەردی ناو هۆڵەکە دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: ئەدیب لەسەر قەنەفەی جەنازەکە پاڵکەوتووە. بەتانییەکی لەسەریدایە. پرخەی بەرزە، وەک هاوارکردن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەرامبەری، نالی لەسەر کورسییەکە بە دانیشتنەوە خەوتووە. هەناسەی بە سەختی دەدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب وردەوردە خەبەری دەبێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەیەوێت ئاو بخوات. سەیری دوروبەری خۆی دەکات، ئاوی لێ نیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەست دەبات بۆ ژێر قەنەفەکە، شتێکی داوێت بیهێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستی ئەدیب، لە ژێر قەنەفەکە شتێکی هەست پێدەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب وەستا"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "قەنەفەکە هەڵدەکاتەوە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ناو قەنەفەکە، تەرمی گەشە. چاوەکانی داخراون. ئاردی شیرینی هێشتا لە دەموچاویدایە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب ڕووماوە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "REVERSE SHOT: نالی، خەبەری بووەتەوە. چاوەکانی پڕ لە ماندوێتی و سترێس. سەیری ئەدیب دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب بە چاوی خەواڵوی سەیری جەنازەکەی گەشە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی، بە خێرایی، پاڵ بە ئەدیبەوە ئەنێت. ڕیفلێکسە، بیرکردنەوە نییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب فڕیی دەیەتەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب دەکەوێت"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سەری دەكەوێت بەسەر بەردی پەیكەرەكەدا"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(ئەوەی لە دیمەنی ٢١ لە گۆشەی هۆڵەکەدا بینرابوو)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: خوێن لە سەری دەڕژێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو لای ئەدیب دەڕوات. بەدەم قسەکردنەوە، هێشتا وا دەزانێت ئەدیب زیندووە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە خێرایی)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وابزانە هیچت نەبینیوە، دوای ئەوە تۆ بۆ لەخۆتەوە دەستکاری شتە تایبەتییەکانی من ئەکەی؟ هەستە بڕۆ، دەموچاوت بشۆ. سەرخۆش ئێرەش بەجێ بهێڵە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی نزیک دەبێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: سەیری ئەدیب دەکات، خوێن لە سەری دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست بە ڕاوەشاندنی دەکات. هەوڵدەدات هەڵیبسێنێت. بەئاگای بهێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب، لاشەیەکی ساردە لە باوەشی نالیدا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "مردووە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی شۆک دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "پێکەنین و گریان تێکەڵ دەکات. هەڵدەستێت. بەرەو لای قەنەفەکە دەڕوات، قەنەفەکە هێشتا کراوەتەوە. سەیری تەرمەکەی گەشە دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بە گریانەوە)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "گەشەی جوان... تۆ جارێ میوانی خۆمی. لێرە بە، با ئەم میوانە بەڕێ بکەم. یەمەوە بۆ لات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنەکە لەسەر دەموچاوی گەشە دەوەستێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: گەشە، ئارام. ئاردی شیرینی لە دەوری لێویدایە. وەک ئەوەی خەوتبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-034",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سییەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . ناو سەیارەی ئەدیب . سەرجادە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: سەیارەی ئەدیب لەسەر جادەیەکی تاک. بایەکی بەقوەت لە پەنجەرەکانەوە دێتە ناوەوە. کەشەکە ماتەمینە، ئاسمان هەورەبار و سارد."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لێیدەخورێت. دەستی لەسەر سوکانەکەیە. چاوی لەسەر جادەکەیە بەس چاوی تیایە نیە، سەیری هیچ ناکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "REVERSE SHOT: ئەدیب لە کورسیی تەنیشتدا. پاڵکەوتووە، دەموچاوی بۆ نالییە. چاوی کراوەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیرێکی ئەدیب دەکات. ئەدیب سەیری ئەکات بە چاوی مردوو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەموچاوی نالی. چاوی پڕە لە ترس و شتێک کە لە ترس نزیکترە، زانینی ئەوەی کە ئەمە ڕاستییە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەدیب لە تاسەیەکدا ئەکەوێتە ناو گاعێکەوە، لاشەکەی لە کورسییەکەوە دەخلیسکێت. نالی قاپی گاز دەدا، سەیارەکە پەلەیەک دەکات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-035",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و یەکەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . ناوبەینی دوو گرد"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT: دیمەنی درەختەکان لە هەوایەکی ماتەمدا. خاک و خۆڵ. هیچ شتێکی زیندوو نیە جگە لە با."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیارەکەی ئەدیب لێ دەخوڕێت بۆ شوێنێک کە زۆر دوور نییە لە ماڵەکەوە. جادەیەکی تەسک و تاریک. ڕادەوەستێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەرگای سەیارەکە دەکاتەوە. تەرمی ئەدیب فڕێ دەداتە دەرەوە. سەیارەکە جێدەهێڵێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە ڕاکردن دەگەڕێتەوە بەرەو ماڵەکە. تووشی پانیک بووە، بە توندی هەناسە دەدات، هەڵدەخلیسکێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەکەوێت. هەڵدەستێتەوە. بەردەوام دەبێت لە ڕاکردن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "جادەکە تەسک دەبێتەوە بۆ کۆڵانێکی تاریک لە نێوان دیوارەکاندا. نالی خەریکە دووبارە دەکەوێت، لێواری ڕێگاکە بەرەو نەمان دەچێت. خۆی دەگرێتەوە، بە زەحمەت، بەردەوام دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەگاتە ماڵەکە. دەچێتە ژوورەوە. دەرگاکە بە توندی دادەخات. لە پشت دەرگاکەوە دەخلیسکێتە خوارەوە، هەناسە دەدات، دەلەرزێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-036",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و دووەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . ناوەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەناو باخەکە دەردەکەوێت. هیالک و ماندوو. تەپوتۆز لەسەر جلەکانییەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستی نالی، کلیل لەناو دەستییەتی. دەستەکانی لەرزان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەرگاکە دەکاتەوە. ماڵەکە بەتاریکییەوە. ڕووناکیی پەنجەرەکان کزتر بووە، ئاسمان هەورەبار."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری چواردەوری دەکات، ڕوخساری پڕە لە توڕەیی و ماندوێتی. هەناسەیەکی قوڵ ئەکێشێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: گڵۆپی سوری کامێراکانی چاودێری، هەڵواسراون. ئەم کامێرایانە هەموو شتیان تۆمارکردووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی کورسییەک ڕائەکێشێت، ئەچێتە سەری، نزیک دەبێتەوە لە کامێراکان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "MONITOR POV: مۆنیتەری کامێراکان، نالی یەکە یەکەی کامێراکان سەیر ئەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کاتێک نالی لەلای مەلەوانگەکەوە بووە، گەشە هەوڵی داوە مۆبایلی نالی بکاتەوە. چەندجارێک هەوڵی پاسۆردەکەی داوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای ئەوە، گەشە سەیری درزی دەرگای ژوورەداخراوەکەی کردووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کاتێک نالی لە توالێتدا بوو، گەشە دەستی لە باڵندە وشکراوەکان داوە. لەسەرییان سووراوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بڕیاردەدات هەموو کامێراکان بسڕێتەوە و بیانکوژێنێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "خێرا بەرەو قەنەفەکە دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "قەنەفەکە دەکاتەوە، جەنازەی گەشە دەردەهێنێت، ئەخاتە باوەشی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "STEADICAM FOLLOW: نالی لاشەی گەشە لە باوەشیدا، بەرەو ژوورەداخراوەکە دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەرگای ژوورەکە دەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ژوورەکەدا چەندین وێنەی جیاوازی تەمەنی نالی تێدایە، لە ئەوروپا، لەگەڵ پیاوێک و ژنێک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە نێوان وێنەکاندا، نالی دانەیەکیان هەڵدەگرێت. ژنێک. ڕێک لە گەشە دەچێت، بەڵام بە ماکیاژێکی جیاواز، قژێکی جیاواز، جلوبەرگی جیاواز. ژنێکی جیاواز. یان هەر خۆیەتی؟"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری وێنەکە دەکات. هیچ وشەیەک ناڵێت. تەنها ڕووخساری خۆی و وێنەکە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەیخاتەوە جێی خۆی. بە وریایییەوە. وەک ئەوەی لەوانەیە بشکێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لاشەی گەشە دادەنێت. سەیری وێنەکان دەکات. سەیری دەموچاوی گەشە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "MATCH CUT: دەموچاوی پێکەنیناوی بوکەڵە → دەموچاوی بوکەڵە لە جامی سەیارەکەدا."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-037",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و سێیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . ناو سەیارەکەی نالی . سەرجادە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەردەوامی MATCH CUT: دەموچاوی بوکەڵەکە لە جامی سەیارەوە نوساوە. هەستێکی ناخۆش و ترسناکی ئەبەخشێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لێیدەخورێت. جادەی سیتەک. بێدەنگ."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-038",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و چوارەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . دەشتێکی تەخت . لای چەند تەنکەرەیەکی وەرگەڕاو"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT: دەشتێکی تەخت. تەنکەرە وەرگەڕاوەکان لە دوورەوە دەردەکەون، قاچیان بەرەو ئاسمان. ئەم شوێنە وەکو گۆڕستانی ماشێنەکانە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکەی نالی بە هێواشی لە قەڕاخی جادەکەوە دێت. ئەوەستێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە سەیارەکەی دادەبەزێت. سەیری دەوروبەری ئەکات. چۆڵ و بێدەنگ. هیچ کەسی لێ نیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە سنوقی دواوەی سەیارەکە، پاچ و خاکەنازێک دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەست ئەکات بە هەڵکەندنی چاڵ لە زەوییەکی وشکدا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT، STATIC CAMERA: کامێرا ناجووڵێت. نالی لە دوورەوە. دەنگی خاکەنازەکە لە زەوی وشکدا، تاک دەنگی دیمەنەکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەر ئەکەنێت. زوو زوو سەیری دەوروبەری ئەکات، ترسی هەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای کەمێک، ئەوەستێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستەکانی نالی. لەرزان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی جگەرەیەک دادەگیرسێنێت. دووکەڵی جگەرەکە بەرەو ئاسمانی خاوەن دەچێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شتێکی بەبیرییەوە دێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو دەرگای دواوەی سەیارەکە دەچێت. بوکەڵەکە دەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: مۆبایلی گەشە، لەنێوان شتەکانی لە جانتاکەیدا. نالی دەریدەهێنێت. دایدەگیرسێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "شەحنی کەمە"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەوڵی کردنەوەی پاسۆرد ئەدات، یەکەم جار، نا. دووەم جار، نا. سێیەم جار، نا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەیخاتەوە جێگای خۆی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی نەفەسێکی قوڵ لە جگەرەکەی ئەدات. سەیری دوور ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT: ئاسمان، کاتی ماوە بۆ تاریکبوون. ڕەنگی ئۆرەنجی ئاسمان دەستی بە مردن کردووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو بوکەڵەکە دەگەڕێتەوە. لاشەی گەشە، لە پارچە پەڕۆیەکەوە پێچراوەتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دەستی نالی، ناسنامەی گەشە لەنێوان پەنجەکانییەتی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "دەستەکانی ئەلەرزن"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ناسنامەکە لە تەنیشتی لاشەکەوە دادەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەموو شتەکانی تری جانتاکە ئەخاتە ناو ئاگرەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "جگەرەکەی ئەخاتە ناو ئاگرەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "STATIC WIDE SHOT: نالی وەستاوە. سەیری سوتانی ئاگرەکە ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی. تەنها دەنگی ئاگر و با."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ڕووناکیی ئاگرەکە لە ڕوخساری نالیدا. چاوەکانی وشکن، نە گریان نە هیچ. تەنها سەیرکردن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری بوکەڵەکە ئەکات، سەری ناو جامی سەیارەوە نوساوە و سەیری دەرەوە ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی ئەڕوات"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ناسەیرکردنەوە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT، STATIC: دەشت. ئاگرەکە بچوک ئەبێت. سەیارەکەی نالی دوور ئەبێت. لاشەی گەشە لەتەنیشتی ناسنامەکەیدا، تەنها."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CUT TO:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT، HILLTOP: نالی لە بەرزاییەکەوە، لەناو سەیارەکەیدا، سەیری ڕووناکیی ئەمبواڵنسێک ئەکات کە لە دوورەوە دێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "چەند نەفەرێک دادەبەزن. یەکێکیان وێنەگرتن دەست پێدەکات. دوو نەفەری تر ماسکیان بەستووە، لاشەکە پاڵدەخەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ڕوخساری نالی، ڕووناکیی ئەمبواڵنسەکە لە چاوەکانییەوە ئاوادەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-039",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و نۆیەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . دەشتێکی وشک"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەناو سەیارەکەی دانیشتووە. تاریکی بەتەواوی دایپۆشیوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "SOUND DESIGN: دەنگی حەشەرەی شەوانە، سەیر و ترسناک. ئەم دەنگە وەکو دەنگی مەکینەیەکە، بەردەوام و مێکانیکی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە سەیارەکەی دادەبەزێت. بەرەو چاڵەکە دەڕوات. دوای ئەوە بەرەو تەنکەرەکان دەڕوات، بەدەوریاندا دەسوڕێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT: نالی لە نێوان تەنکەرە وەرگەڕاوەکاندا، وەکو زیندانییەک لە نێوان دیوارەکانییەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو سەیارەکەی دەگەڕێتەوە. بوکەڵەکە دەکاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نیوەی لەشی گەشە دەردەهێنێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەستێت"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ڕوخساری نالی، هەستێکی پەشیمانی بەهێز."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاگرێک دەکاتەوە. دەنگی حەشەرە و دەنگی بایەکی ترسناک."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەرەو سەیارەکەی ئەڕوات. مۆبایلی گەشە دەردەهێنێت. سەیری ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: شاشەی مۆبایل، چەند نامەیەکی بۆ هاتووە. ناتوانێت بیکاتەوە، قفڵە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەس نامەکان نیوەیان دەتوانێت بخوێنێت، لە notification-ەکانەوە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "INSERT، شاشەی مۆبایل:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "\"...شەو زوو بگەڕێتەوە ماڵەوە...\""
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "\"...نیگەرانتم کوڕە...\""
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە بێدوودڵی مۆبایلی گەشە ئەخاتە ناو ئاگرەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مۆبایلەکەی خۆی دەردەهێنێت. پەیوەندی بە AI ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هێدفۆنەکەی بە تونی ئەخاتە گوێ."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: شاشەی مۆبایلی نالی، \"شەبەکە نیە.\""
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری مۆبایلەکەی ئەکات. لەو کاتەی کە مۆبایلەکەی لە دەستییەتی، ئەمە یەکەم جارە لە سەرەتای فیلمەوە کە نالی بەبێ AI-ە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی مەجبور دەبێت نامەیەک بنوسێت، نە قسەکردن بەڵکو تایپکردن. ئەمە D3 text mode-ە، بەس لەمەودا نە لەبەر ئەوەی کەسی تر لەوێیە، بەڵکو لەبەر ئەوەی شەبەکە نیە و ناتوانێت بینێرێت. ئەنوسێت بۆ هیچکەس."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "INSERT، شاشەی مۆبایل، نامەی نالی:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی (نوسین)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە کۆتاییدا پاڵەوانەکەم جەنازەکە بەجێدێڵێت"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆئەوەی کەسوکاری بیدۆزنەوە و بێ ناو و نیشان نەمێنێتەوە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر پێویستم پێتە بۆ تەواوکردنی چیرۆکەکەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کە هاتیتەوە سەرخەت بۆچونی خۆتم پێبڵێی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: نالی دوای ناردنی نامەکە، بە بێتاقەتی، مۆبایلەکەی دادەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نامەکە نارنرا، \"شەبەکە نیە\" هەر لەسەر شاشەکەیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەری بەرزدەکاتەوە. سەیری ئەمبواڵنسەکە دەکات، لە دوورەوە ڕووناکییەکانی دەبینرێن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "EXTREME WIDE SHOT: ڕووناکیی ئەمبواڵنسەکە لە تاریکییدا. دەرگاکان دادەخرێن. بەخێرایی ئەڕۆن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی سەیری ئەکات. هەر سەیری ئەکات. تا لە تاریکایی شەودا ون ئەبێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-040",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و پێنجەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . بەردەم دوکانێکی مۆبایل"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT، NIGHT: لە دوورەوە نالی دەبینین، سەیارەکەی لەبەردەم دوکانێکی مۆبایل ڕادەگرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە سەیارەکەی دادەبەزێت. دەچێتە ناو دوکانەکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "TIME CUT: نالی دێتەوە دەرەوە. شتێکی کڕیوە، بەکەسە، سیمکارتە، یان تەنها شارژەرە، نازانین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سواری سەیارەکەی دەبێتەوە. بەخێرایی دەڕوات."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-041",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و شەشەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . دەرەوە . ناو سەیارەکەی نالی . قەراخ شار"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیارەکەی نالی لەسەر جادەیەکی بێدەنگی تاریکدایە. شوێنێکی چۆڵ، هیچ عەمودی ڕووناکی و هیچ کامێرایەک تێدا نیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە سەیارەکەی دادەبەزێت. سەیری دەوروبەری ئەکات، دڵنیا ئەبێت کەسی لێ نیە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەگەڕێتەوە ناو سەیارەکەی. زەرفێک دەردەهێنێت، سیمکارتێک ئەخاتە مۆبایلێکی بچوکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "تەلەفۆنێک دەکات"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بێدەنگی، سەیری مۆبایلەکە ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "خێرا پەشیمان دەبێتەوە. دایدەخاتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکە ئەخاتەوە گیرفانی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دوای چەند ساتێک، لاشەی گەشە لە بوکەڵەکە دەردەهێنێت. لە پارچە پەڕۆیەکەوە پێچراوەتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: بنکەی دارێک، هەمان دار. سەیری خوارەوە بکە: لە هەمان ئەو شوێنەی کە لەسەر جادەکە ئاژەڵێکی مردووی لێ بوو، ئێستا نالی خەریکە گەشە لەوێ دابنێت. سێبەری دارەکان بە هەمان شێوە دەکەونە سەر زەوییەکە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەخاتە باوەشی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەرەو لای دارێکەوە دەیبات. دایدەنێت لەسەر خۆی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وردە وردە دێتە دواوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: ڕوخساری نالی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "parenthetical",
                "content": [
                  {
                    "type": "text",
                    "text": "(بەهێواشی، بۆ خۆی)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "خوات لەگەڵ گەشە گیان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ببورە کە ئەبێ بەم شێوەیە بەجێتبهێڵم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خێرا و بەبێ وەستان سواری سەیارەکەی دەبێت و دەڕوات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هیچ ئەسەرێک بەجێناهێڵێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دڵنیاش ئەبێت کە کەس نەیبینوە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-042",
              "notes": "",
