                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چل و سێ (a)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . ناوەوە . هۆڵی شانۆ"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "WIDE SHOT، هۆڵی شانۆیەکی گەورە. کورسییە چۆڵەکان بە ڕیزەکان دادەنیشن لە هەردوو لاوە، بەبێ تاماشاوان. ڕووناکییەکی کز لە سەر شانۆکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە ناوەڕاستی کورسییەکاندا، نالی دانیشتووە بەتەنها. کۆمەڵە کاغەزێکی بەدەستەوەیە، دەقی شانۆنامەکەیە. چاوی پڕە لە فرمێسک، بەس فرمێسکەکان نایەنە خوار."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەسەر شانۆکە، چەند ئەکتەرێک خەریکی تەمرینن. جوڵەیان جوان و مانادارە، دەنگەکانیان هۆڵەکە پڕ دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خەیاڵی ڕۆشتووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەناکاو، لە ناو ئەکتەرەکاندا، کچێکی جوان بە عەزییەکی سورەوە دەردەکەوێت. سەما دەکات. جوڵە و شێوەی لە گەشە دەچێت، بەدەوری ئەکتەرەکاندا دەسوڕێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەپڕ، هەڵدەستێتە سەرپێ. بەدەنگێکی بەرزەوە و پڕ خەمەوە:"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بۆئەمڕۆ تەمرین بەسە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەکتەرەکان بە سەرسوڕمانەوە، هەموو سەیری یەک دەکەن. یەکەیەکە سەرشانۆکە بەجێدەهێڵن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "کچەکەی سوری، ئەویش زۆر بە ئارامی و خەمبارییەوە شانۆکە بەجێدەهێڵێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە گۆشەیەکی شانۆکەوە، نازی بەرەو لای نالی دێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "چی بووە؟ ئاوابکەی هەمووی ئەڕۆن و ئیشەکە ناکرێت. ماوەیەکە نالێکەی جاران نەماوی، زۆر گۆڕاوای."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بێ هیچ قسەیەک، دەقەکەی لە دەستی دەستی نازیدا دادەنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەناو کورسییە چۆڵەکاندا دەڕوات، وەک کەسێکی شەکەت و بێهیوا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نازی سەیری ڕۆشتنی نالی دەکات، تا وردەوردە لە دەرگاکەوە ون دەبێت."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-044",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی سی و نۆ (b)"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . ناوەوە . بنکەی پۆلیس"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ژوورێکی نیوەتاریکی لێکۆڵینەوە لە بنکەی پۆلیس. ڕووناکییەکی کز و زەرد، لامپایەکی سەرمێز."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە ڕوخسارێکی هەڵواسراوەوە بەرامبەر ئەفسەرێک دانیشتووە. دەستەکانی لەسەر مێزەکەن، هەوڵ دەدات جوڵەی پەنجەکانی ئارام بکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە سوچێکی ژوورەکەدا، کچێکی گەنج دانیشتووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "زۆر کاتت ناگرم. ئێمە بۆ چۆنیەتی مردنی ئەدیب بانگمانکردووی، بەس ئەم خانمە تۆی بینیوە و هاتەلامان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە رەوتی گۆڕی، تۆنەکەی گۆڕا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باسی ئەوە دەکات کە تۆ ئاگاداری کەیسی دیارنەمانی و مردنی گەشە ئازادیت، چونکە لە ڕۆژی... گەشە ئازاد دوایین تەلەفۆنی لەگەڵ تۆدا کردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەوتەی پزیشکی لێکۆڵەرەوە، گەشە جەڵدەی دڵ لێیاوە بەهۆی زۆر خواردنی شیرینییەوە. ئەو نەخۆشی شەکرەی هەبووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CAMERA لەسەر دەستەکانی نالی، پەنجەکانی ڕاوەستان."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەپێی لێکۆڵینەوەکانی پۆلیس، دەکرێت کەسێک زانیبێتی نەخۆشی شەکرەی هەیە و ئەو ڕێگەیەی بەکار هێناوە بۆ کوشتنی. لەبەر ئەوەی کەس پێینەزانێت، بکوژ زانیوێتی کە ئەو نەخۆشییەی هەیە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ باسی چی ئەکەی؟ منتان هێناوە بۆ ئێرە بۆئەوەی باسی مردنی کەسێکم بۆبکەن کە پەیوەندی بەمنەوە نیە؟"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەس خۆ ئەدیب ئەناسی وایە؟ بەهەرحاڵ ئەو دوایین تەلەفۆنی لەگەڵ تۆیا بووە، ئێمەش ئەبێت لێکۆڵینەوەی خۆمان بکەین. تەنها تۆش نیت، لەگەڵ هەموو ئەوانەی پەیوەندیان بە کوژراوەوە هەیە لێکۆڵینەوە ئەکەین."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە ساتێک ڕاوەستا."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "واتە هەم ئەدیب و هەم گەشەش، دوادیداریان لەگەڵ تۆ بووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوەی باسی ئەکەین چەنجارێک پەیوەندی کردووە بۆ دەورەی ئەکتەری، بەس لە نزیکەوە یەکمان نەناسیوە. من خەڵک ئەمناسێت لە بوارەکەی خۆماتکایە، توشی کێشەم مەکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تۆنەکەی گۆڕی، ئەمجارە وەکو مامۆستایەکی دەرهێنان قسە ئەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "دەوای ئەوە، تۆ ناڵێیت نەخۆشی شەکرەی هەبووە، کەواتە خۆی مردووە. ئەدیبیش خۆتان ئاگادارن کە بەسەرخۆشی وەرگەڕاوە، من خۆم لە کەس وکاری زیاترم پێناخۆش بووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە، یەکەیەکە. باجارێ باسی گەشە بکەین. ئەگەر خۆی مردبێت، ئەی خۆی چۆن ئەتوانێت چەرچەف لەخۆیەوە بئاڵێنێت؟ بەڕێزتان، پێتوایە ڕوحی پەیوەندی کردووە بە ئێمەوە؟ نا، کەواتە کەسێک ئاگاداربووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەڵبەتە کەسێک ویستوێتی هاوکاری بکات تا کەسوکاری بیدۆزنەوە. ئەگەر بەپێی قسەکانی تۆ بێت، کەسێک بیەوێت بیکوژێت، ئەیشارێتەوە ونی ئەکرد."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆ پێتوایە ئەمەش شانۆیە، بەئاسانی چیرۆکەکە تەواو بکەیت؟ بەڕێزم ئەمە ڕوداوێکی ڕاستەقینەیە، خەیاڵی نیە. دواتر پێویستناکا تۆ وەکوچۆن لە دەورەی ئەکتەرییا قسە ئەکەی و مامۆستای، قسەش بۆ من بکەیت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بێدەنگ ئەبێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەو خانمە ئەبینیت؟ ئەوە ناوی ئەوینە، پێکەوە لەگەڵ گەشە لە ماڵێکدا ئەژیان. پێمخۆش بوو گوێت لە قسەکانی بێت، ئەوکاتە ئەزانی ئێمە بۆ تۆمان هێناوە بۆئێرە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە ئەوین بانگ دەکات. ئەوین بەرەو لایان دێت، دادەنیشێت لەلایانەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم خانمە ئاگادار بووە کە چەندین جار گەشە تەلەفۆنی لەگەڵ تۆیا کردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڤین"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "جەنابی ئەفسەر، من نازانم ئەوان یەکیان بینیوە یان نا. بەس لەم ئەخیرانەیا وتی لەگەڵ دەرهێنەرێکدا لە پەیوەندیام و ئەمەوێ فێری نواندنم بکات. بەس چەندین جار بینیومە، گەشە بە ڤیدیۆ قسەی لەگەڵ ئەما کردووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "پۆلیس"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "بەڕێز نالی، ئەبێت هەموو ئەو نامە و تەلەفۆنانەمان بەیتێ کە لەگەڵ گەشەیا گۆڕیوتانەتەوە. وەک ئەوین خانم، کە هەمووی خستە بەردەستمان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە سەیرێکی ئەوین دەکات. ئەوین سەری دادەخات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "من کێشەم نیە، هەرچەنە لەبەر ئەوەی تەلەفۆنەکەم جێگای کەم بوو، زۆربەی کات بە ڤیدیۆ قسەمان ئەکرد. فەرموون ئەتوانن سەیری بکەن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوین ئەیەوێت شتێک بڵێت، نالی لەقسەکردن ئەوەستێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "فەرموو"
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەڤین"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "جەنابی ئەفسەر، گەشە لە ماڵەوەیان ڕایکردبوو. من گرتبوومە خۆم، زۆر هەوڵم ئەیا ببێت بە شتێک و ماڵێک و ئیشی خۆی هەیەبێت. بەس کچێکی زۆر سەرکێش بوو."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بە بیستنی ئەو قسانە، شۆک دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CAMERA لەسەر ڕووخساری نالی دەوەستێت، دەنگی ئەوین ناڕونتر ئەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەفسەرەکە داوا لەنالی دەکات لەگەڵی بڕوات بۆ ژوورێکی تر، سەبارەت بە کەیسی مردنی ئەدیبە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەستێت، لە دەرگاکەدا ساتێک ئەوەستێت، بۆ ئاخرین جار سەیری ئەوین دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەوین سەرینەبەرزکردەوە"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-045",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چلەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . سەیارەکەی نالی لە قەراخ شار"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی خەریکی سەیارە لێخوڕینە، لەناو ترافیکا وەستاوە. دەنگی هۆڕینی سەیارە ئەوناوەی زیاتر قەرەباڵغکردووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکەی لەسەر داشبۆردەکە، هەڵی ئەگرێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "سڵاو ئومێد، باشی؟ ویستم بزانم ڤێرژنی تازەی هەرنەهات؟ ئەوەی پێشتر هیچی نەگەڕایەوە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "ساتێک بێدەنگی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشترە هەر نەیەتەوە، تازە نامەوێ."
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئومێد (بەدەنگ)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "باشە نالی گیان، وادیارە لە شتێک بێتاقەتی."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "تۆزێک هیالکم. تۆ وازلەوە بێنە، ئەرێ هەر نەهات بۆ ئەوەنەی پێچوو؟"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئومێد (بەدەنگ)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "پەلەونەبێ، چەن ڕۆژێکی تر یەت. خۆم تەلەفۆن بۆئەکەم."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "هەر ئەمڕۆ و سبەیم پێئەکەی. خۆزگە شتێکیان دروست ئەکرد هەتاهەتایی بوایا."
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "ئومێد (بەدەنگ)"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کوڕی باش، بۆ ئینسان هەتاهەتایی ئەمێنێتەوە؟ تا شتەکانیش هەتاهەتایی بمێنەوە. هەموو شتێک لەم ژیانەیا کاتییە و تەواو ئەبێت. گوێمەیەرێ، کە ڤێرژنی تازە هات پێت ئەڵێم."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی ئومێد وردەوردە کز ئەبێت، ناڕون دەبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی تەلەفۆنەکەی لەسەر داشبۆردەکە دادەنێت. بەردەوام لە ترافیکایە، گیری خواردووە."
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-046",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چل و دووەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "شەو . ناوەوە . باخەکەی نالی، دیمەنێکی سوریالی"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لەناو ماڵەکەدا، هەست بە ونبوون ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری دەوروبەری خۆی ئەکات، ئاژەڵە وشکراوەکان لەسەر دیوارەکان، چاویان بریقە ئەدات لە تاریکیدا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ترسێکی قوڵ و خەمبارییەک دەیگرێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەڕواتە دەرەوەی باخەکە، بەڕامبەر ماڵەکە دادەنیشێت. وەک ئەو دانیشتەنەی کە پێشتر گەشەی لێبوە، لە Scene 14 دا."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لە چاوی نالییەوە ئەبینین:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئاگرێک، ماڵەکەی ئاگری گرتووە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەگەکەی (گوڵە)، یاری دەکات لەناو ئاگرەکەدا. وەک ئەوەی پێیخۆشبێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بوکەڵەیەک، دێتە دەرەوە بەسەماکردن. وەک ئەوەی گەشەبێت، سەمایەکەی لەو سەمایەدا دەچێت کە لە شانۆکەدا بینیبووی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "ئەم دیمەنە بەردەوام ئەبێت، تا لەناکاو:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی سەگەکەی نالی دێت، گوڵە دەوەڕێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی بەئاگادێتەوە"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "CUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "CUT"
                  }
                ]
              }
            ]
          },
          {
            "type": "scene",
            "attrs": {
              "id": "scene-047",
              "notes": "",
              "revisionFlag": null,
              "metadata": {
                "linkedScenes": [],
                "references": [],
                "production": {}
              }
            },
            "content": [
              {
                "type": "sceneHeading",
                "attrs": {
                  "setting": "",
                  "time": "",
                  "headingStyle": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "دیمەنی چل و سێیەم، گەڕانەوە بۆ دیمەنی دووەم"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "رۆژ . دەرەوە . باخەکە"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "SOUND FIRST: ئاخ"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی باخەوانەکە دێت، پێش ئەوەی کامێرا بگەڕێتەوە بۆ باخەکە. ئەو دەنگەی Scene 2 یە، بەردەوامە لە باسکردنی چیرۆکی مردنی کوڕ و کچەکەی باخەکەی بەرامبەریان."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وردەوردە، وێنە دێتەوە:"
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی لە باخەکەدایە. سەیری سەگەکەی دەکات، گوڵە لە پۆلیس و خەڵکەکەدا کە لە باخەکەی بەرامبەریانەوە، دەوەڕێت."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "جا من باوکی کوڕەکەم ئەناسم، پیاوێکی زۆر باشە. ئێستا کەوتوونەتە کێشە لەگەڵ ماڵی کچەکە. باوکی کوڕەش نازانێ خەمی مردنی کوڕەکەی بخوات، یان وەڵامی ماڵی کچە و خەڵک بداتەوە، کە ئەوان چی یەکبوون و چیان کردووە بەوشەوە پێکەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەمکاتەدا، نالی سەیری دەوروبەری دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری دەستی دەکات، کە گرتوێتی بەریدەدات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیر ئەکات، پەنجەی نەبڕیووە."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەوان"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کاک نالی، سەرمئێشانی. من ئەڕۆم. بەس هەرلەماڵبیت باشە، چونکە پۆلیسەکان وتیان کامێرای چاودێری هەموو دراوسێ باخەکان سەیر ئەکەین. ئیتر نازانم بۆچییە، ئەوە. من ئەڕۆم، خوات لەگەڵ."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی وەک ئەوەی لە خەوێکی ناخۆش بەئاگابێتەوە، سەیرێکی باخەوانەکە دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "بەسەر خواحافیزی لێدەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەمکاتەدا، دەنگی مۆبایلەکەی دێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "سەیری ئەکات، گەشەیە. ڤیدیۆکۆڵ ئەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "لەیەک کاتدا، لە باخە تەنیشتەکەدا، سەیارەیەکی پزیشکی دادوەری ڕادەگرێت. دوو کەس بە جلی سپییەوە دارەبەمەیەک دەردەهێنن."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "CLOSE ON: دارەبەمەکە، تەرمێک بە پەڕۆیەکی سپی داپۆشراوە. لە سەرێکییەوە، پارچەیەک قژ هاتووەتە دەرەوە. و لەسەری، تەوقەیەكی قژ (hair clip)."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "هەمان ئەو تەوقەیەی گەشە لەسەری بوو کاتێک نالی بۆ یەکەمجار لەسەر ئەو شۆستەیە بینی."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی دەوەستێت. تێ دەمێنێت."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "مۆبایلەکەی هێشتا لە دەستیدایە، گەشە هێشتا لەسەر شاشەکەیە، تەلەفۆن دەکات."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "نالی هەڵدەسێتە سەرپێ، بەرەو دەرگای ناو باخەکەی دەڕوات، وەڵامی گەشە دەداتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "وردەوردە کامێرا دوور ئەکەوێتەوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "باخەکە و نالی و سەگەکەی دەردەکەون، لەدووراوە."
                  }
                ]
              },
              {
                "type": "action",
                "content": [
                  {
                    "type": "text",
                    "text": "دەنگی گەشە بە ناڕونی دەبیسترێت، قسە دەکات."
                  }
                ]
              },
              {
                "type": "character",
                "content": [
                  {
                    "type": "text",
                    "text": "· · ·"
                  }
                ]
              },
              {
                "type": "dialogue",
                "content": [
                  {
                    "type": "text",
                    "text": "کۆتایی"
                  }
                ]
              },
              {
                "type": "transition",
                "attrs": {
                  "presetType": "FADE OUT"
                },
                "content": [
                  {
                    "type": "text",
                    "text": "FADE OUT."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}