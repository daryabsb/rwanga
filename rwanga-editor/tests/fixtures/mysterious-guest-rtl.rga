              {
                "type": "text",
                "text": "The Unknown Guest"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "سیناریۆی فیلم"
              }
            ]
          },
          {
            "type": "paragraph",
